<form class="{{cssClass}} {{actor.type}} flexcol" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Name" />
      </h1>
      <div class="header-stats">
        {{#each stats as |stat|}}
          <label class="header-stat" title="{{stat.label}}">
            <span class="stat-short">{{stat.shortLabel}}</span>
            <input type="number" name="system.stats.{{stat.slug}}.value" value="{{stat.value}}" data-dtype="Number" />
          </label>
        {{/each}}
      </div>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="overview">{{localize "CYBER_BLUE.Sheet.Tabs.Overview"}}</a>
    <a class="item" data-tab="skills">{{localize "CYBER_BLUE.Sheet.Tabs.Skills"}}</a>
    <a class="item" data-tab="cyberware">{{localize "CYBER_BLUE.Sheet.Tabs.Cyberware"}}</a>
    <a class="item" data-tab="inventory">{{localize "CYBER_BLUE.Sheet.Tabs.Inventory"}}</a>
    <a class="item" data-tab="notes">{{localize "CYBER_BLUE.Sheet.Tabs.Notes"}}</a>
  </nav>

  <section class="sheet-body">
    <div class="tab active" data-group="primary" data-tab="overview">
      <section class="sheet-panel health-panel">
        <h2>{{localize "CYBER_BLUE.Sheet.Labels.Health"}}</h2>
        <div class="health-grid">
          <div class="health-block health-hp">
            <h3>HP</h3>
            <div class="resource-fields">
              <input type="number" name="system.resources.hp.value" value="{{health.hp.value}}" data-dtype="Number" />
              <span>/</span>
              <input type="number" value="{{health.hp.max}}" disabled />
            </div>
          </div>

          <div class="health-block health-threshold">
            <h3>{{localize "CYBER_BLUE.Sheet.Labels.SeriousWoundThreshold"}}</h3>
            <div class="health-value">{{health.seriousWoundThreshold}}</div>
          </div>

          <div class="health-block health-threshold">
            <h3>{{localize "CYBER_BLUE.Sheet.Labels.DeathSave"}}</h3>
            <div class="health-value">{{health.deathSave}}</div>
          </div>

          <div class="health-block health-effects">
            <h3>{{localize "CYBER_BLUE.Sheet.Labels.HealthEffects"}}</h3>
            <div class="health-effects-list">
              {{#if health.effects.length}}
                {{#each health.effects as |effect|}}
                  <button type="button" class="health-effect" data-action="open-health-effect" data-effect-id="{{effect.id}}" title="{{#if effect.canEdit}}Open and edit effect{{else}}Open effect{{/if}}">
                    <img src="{{effect.icon}}" alt="{{effect.name}}" />
                    <span>{{effect.name}}</span>
                    {{#if effect.duration}}
                      <span class="effect-duration">{{effect.duration}}</span>
                    {{/if}}
                  </button>
                {{/each}}
              {{else}}
                <p class="hint">No direct health effects on this character.</p>
              {{/if}}
            </div>
          </div>
        </div>
      </section>

      <section class="quick-stats-row">
        <div class="sheet-panel stat-card armor-card">
          <span class="stat-short">{{localize "CYBER_BLUE.Sheet.Labels.StoppingPower"}}</span>
          <select name="system.combat.activeArmorItemId">
            {{#if armor.options.length}}
              {{#each armor.options as |option|}}
                <option value="{{option.id}}" {{#if (eq option.id ../armor.activeId)}}selected{{/if}}>{{option.name}}</option>
              {{/each}}
            {{else}}
              <option value="">{{localize "CYBER_BLUE.Sheet.Labels.NoArmor"}}</option>
            {{/if}}
          </select>
          <div class="resource-fields">
            <input type="number" value="{{armor.current}}" disabled />
            <span>/</span>
            <input type="number" value="{{armor.max}}" disabled />
          </div>
        </div>

        <label class="sheet-panel stat-card move-card">
          <span class="stat-short">{{move.shortLabel}}</span>
          <input type="number" name="system.stats.move.value" value="{{move.value}}" data-dtype="Number" />
        </label>

        <div class="sheet-panel stat-card move-card">
          <span class="stat-short">{{psyche.label}}</span>
          <div class="resource-fields">
            <input type="number" name="system.resources.psyche.value" value="{{psyche.value}}" data-dtype="Number" />
            <span>/</span>
            <input type="number" value="{{psyche.max}}" disabled />
          </div>
        </div>

        <div class="sheet-panel stat-card move-card luck-card">
          <span class="stat-short">{{luck.label}}</span>
          <div class="resource-fields">
            <input type="number" name="system.resources.luck.value" value="{{luck.value}}" data-dtype="Number" />
            <span>/</span>
            <input type="number" value="{{luck.max}}" disabled />
          </div>
        </div>
      </section>

      {{#if combatWeapons.length}}
        <section class="sheet-panel combat-weapon-panel">
          <table class="embedded-table combat-weapon-table">
            <colgroup>
              <col />
              <col class="column-compact" />
              <col class="column-compact" />
              <col class="column-compact" />
              <col class="column-controls" />
            </colgroup>
            <thead>
              <tr>
                <th>Weapon</th>
                <th class="numeric-column">{{localize "CYBER_BLUE.Sheet.Labels.Attack"}}</th>
                <th class="numeric-column">{{localize "CYBER_BLUE.Sheet.Labels.RateOfFire"}}</th>
                <th class="numeric-column">{{localize "CYBER_BLUE.Sheet.Labels.Mag"}}</th>
                <th class="numeric-column">Controls</th>
              </tr>
            </thead>
            <tbody>
              {{#each combatWeapons as |weapon|}}
                <tr data-item-id="{{weapon.itemId}}">
                  <td>
                    <button type="button" class="item-name-link embedded-name">
                      <span>{{weapon.name}}</span>
                    </button>
                  </td>
                  <td class="numeric-column">
                    <button type="button" data-action="weapon-attack" data-weapon-index="{{weapon.weaponIndex}}" title="{{weapon.attackTooltip}}">
                      {{weapon.attackLabel}}
                    </button>
                  </td>
                  <td class="numeric-column">{{weapon.rateOfFire}}</td>
                  <td class="numeric-column">
                    {{#if weapon.showsAmmo}}
                      <div class="resource-fields compact-resource">
                        <input type="number" value="{{weapon.ammoCurrent}}" data-action="update-item-field" data-field-path="system.weapons.{{weapon.weaponIndex}}.ammoCurrent" data-dtype="Number" />
                        <span>/</span>
                        <input type="number" value="{{weapon.magazine}}" disabled />
                      </div>
                    {{else}}
                      <span>&mdash;</span>
                    {{/if}}
                  </td>
                  <td class="numeric-column">
                    {{#if weapon.showsAmmo}}
                      <button type="button" data-action="weapon-reload" data-weapon-index="{{weapon.weaponIndex}}" data-magazine="{{weapon.magazine}}" title="{{localize "CYBER_BLUE.Sheet.Buttons.Reload"}}">
                        <i class="fas fa-rotate-right"></i>
                      </button>
                    {{/if}}
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </section>
      {{/if}}

      {{#if enrichedRoleOverviewFeatures.length}}
        <section class="sheet-panel role-overview-panel">
          {{#each enrichedRoleOverviewFeatures as |feature|}}
            <section class="role-overview-feature" data-item-id="{{feature.roleId}}">
              <h4 class="roleCategory">{{feature.roleName}}</h4>
              {{#if (eq feature.kind "networker")}}
                <div class="role-overview-html">{{{feature.content}}}</div>
              {{/if}}
              {{#if (eq feature.kind "protean")}}
                <div class="role-focus-summary">
                  <span>{{localize "CYBER_BLUE.Role.Pool"}}: {{feature.totalPoints}}</span>
                  <span>{{localize "CYBER_BLUE.Role.Remaining"}}: {{feature.remainingPoints}}</span>
                </div>
                <table class="embedded-table role-focus-table">
                  <colgroup>
                    <col />
                    <col class="column-compact" />
                  </colgroup>
                  <thead>
                    <tr>
                      <th>{{localize "CYBER_BLUE.Role.Focus"}}</th>
                      <th class="numeric-column">{{localize "CYBER_BLUE.Sheet.Labels.Rank"}}</th>
                    </tr>
                  </thead>
                  <tbody>
                    {{#each feature.foci as |focus|}}
                      <tr data-item-id="{{../roleId}}">
                        <td title="{{focus.description}}">{{focus.name}}</td>
                        <td class="numeric-column">
                          <input type="number" value="{{focus.points}}" min="{{focus.minPoints}}" max="{{focus.maxPoints}}" step="{{focus.step}}" data-action="update-item-field" data-field-path="system.proteanFoci.{{focus.focusIndex}}.points" data-dtype="Number" />
                        </td>
                      </tr>
                    {{/each}}
                  </tbody>
                </table>
              {{/if}}
              {{#if (eq feature.kind "leader")}}
                {{#each feature.leaderFeatures as |leaderFeature|}}
                  <div class="role-leader-feature">
                    <h5>{{leaderFeature.name}}</h5>
                    {{#if leaderFeature.description}}
                      <p class="hint">{{leaderFeature.description}}</p>
                    {{/if}}
                    <div class="team-member-list">
                      {{#each leaderFeature.members as |member|}}
                        <button type="button" class="item-name-link embedded-name team-member-link" data-action="open-team-member" data-actor-id="{{member.id}}">
                          <img src="{{member.img}}" alt="{{member.name}}" />
                          <span>{{member.name}}</span>
                        </button>
                      {{/each}}
                    </div>
                  </div>
                {{/each}}
              {{/if}}
              {{#if (eq feature.kind "specialist")}}
                <div class="specialty-summary-list">
                  {{#each feature.specialties as |specialty|}}
                    <div class="specialty-summary">
                      <strong>{{specialty.name}}</strong>
                      <span>{{localize "CYBER_BLUE.Sheet.Labels.Rank"}} {{specialty.rank}}</span>
                      {{#each specialty.unlockedSections as |section|}}
                        <div class="role-overview-html">{{{section.enrichedContent}}}</div>
                      {{/each}}
                    </div>
                  {{/each}}
                </div>
              {{/if}}
            </section>
          {{/each}}
        </section>
      {{/if}}

      {{#if otherResources.length}}
        <section class="resources-grid overview-resources">
          {{#each otherResources as |resource|}}
            <div class="sheet-panel resource-card">
              <div class="resource-name">{{resource.label}}</div>
              <div class="resource-fields">
                <input type="number" name="system.resources.{{resource.slug}}.value" value="{{resource.value}}" data-dtype="Number" />
                <span>/</span>
                <input type="number" value="{{resource.max}}" disabled />
              </div>
            </div>
          {{/each}}
        </section>
      {{/if}}

      <section class="traits-grid">
        <div class="sheet-panel traits-role-panel">
          <table class="embedded-table">
            <colgroup>
              <col />
              <col class="column-compact" />
              <col class="column-controls roles-controls-column" />
            </colgroup>
            <thead>
              <tr>
                <th>Role</th>
                <th class="numeric-column">{{localize "CYBER_BLUE.Sheet.Labels.Rank"}}</th>
                <th>Controls</th>
              </tr>
            </thead>
            <tbody>
              {{#each roles as |role|}}
                <tr data-item-id="{{role.id}}">
                  <td>
                    <button type="button" class="item-name-link embedded-name">
                      <img src="{{role.img}}" alt="{{role.name}}" />
                      <span>{{role.name}}</span>
                    </button>
                  </td>
                  <td class="numeric-column">{{role.system.rank}}</td>
                  <td>
                    <div class="embedded-controls">
                      {{#unless role.isAlwaysActive}}
                        <button type="button" data-action="toggle-active-role" title="{{#if role.isLowRankActive}}{{localize "CYBER_BLUE.Sheet.Labels.ClearActive"}}{{else}}{{localize "CYBER_BLUE.Sheet.Labels.SetActive"}}{{/if}}">
                          <i class="fas {{#if role.isLowRankActive}}fa-toggle-on{{else}}fa-toggle-off{{/if}}"></i>
                        </button>
                      {{/unless}}
                      <button type="button" data-action="move-item" data-direction="up" title="{{localize "CYBER_BLUE.Sheet.Buttons.MoveUp"}}">
                        <i class="fas fa-arrow-up"></i>
                      </button>
                      <button type="button" data-action="move-item" data-direction="down" title="{{localize "CYBER_BLUE.Sheet.Buttons.MoveDown"}}">
                        <i class="fas fa-arrow-down"></i>
                      </button>
                      <button type="button" data-action="edit-item" title="{{localize "CYBER_BLUE.Sheet.Buttons.Edit"}}">
                        <i class="fas fa-pen"></i>
                      </button>
                      <button type="button" data-action="delete-item" title="{{localize "CYBER_BLUE.Sheet.Buttons.Delete"}}">
                        <i class="fas fa-trash"></i>
                      </button>
                    </div>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>

        <div class="sheet-panel traits-ability-panel">
          <table class="embedded-table">
            <colgroup>
              <col />
              <col class="column-compact" />
              <col class="abilities-note-column" />
              <col class="column-controls roles-controls-column" />
            </colgroup>
            <thead>
              <tr>
                <th>Ability</th>
                <th class="numeric-column">{{localize "CYBER_BLUE.Sheet.Labels.Rank"}}</th>
                <th>{{localize "CYBER_BLUE.Sheet.Labels.Note"}}</th>
                <th>Controls</th>
              </tr>
            </thead>
            <tbody>
              {{#each abilities as |ability|}}
                <tr data-item-id="{{ability.id}}">
                  <td>
                    <button type="button" class="item-name-link embedded-name">
                      <img src="{{ability.img}}" alt="{{ability.name}}" />
                      <span>{{ability.name}}</span>
                    </button>
                  </td>
                  <td class="numeric-column">
                    {{ability.system.rank}}
                    {{#if ability.maxRankDisplay}}
                      / {{ability.maxRankDisplay}}
                    {{/if}}
                  </td>
                  <td class="embedded-summary">{{ability.system.note}}</td>
                  <td>
                    <div class="embedded-controls">
                      <button type="button" data-action="move-item" data-direction="up" title="{{localize "CYBER_BLUE.Sheet.Buttons.MoveUp"}}">
                        <i class="fas fa-arrow-up"></i>
                      </button>
                      <button type="button" data-action="move-item" data-direction="down" title="{{localize "CYBER_BLUE.Sheet.Buttons.MoveDown"}}">
                        <i class="fas fa-arrow-down"></i>
                      </button>
                      <button type="button" data-action="edit-item" title="{{localize "CYBER_BLUE.Sheet.Buttons.Edit"}}">
                        <i class="fas fa-pen"></i>
                      </button>
                      <button type="button" data-action="delete-item" title="{{localize "CYBER_BLUE.Sheet.Buttons.Delete"}}">
                        <i class="fas fa-trash"></i>
                      </button>
                    </div>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </section>
    </div>

    <div class="tab" data-group="primary" data-tab="skills">
      <section class="sheet-panel">
        <div class="skill-table-container">
          <div class="skill-header skill-row">
            <span>Skill</span>
            <span class="numeric-column">Stat</span>
            <span class="numeric-column">{{localize "CYBER_BLUE.Sheet.Labels.Rank"}}</span>
            <span>{{localize "CYBER_BLUE.Sheet.Labels.LinkedComponents"}}</span>
            <span class="numeric-column">{{localize "CYBER_BLUE.Sheet.Labels.Modifier"}}</span>
            <span class="numeric-column">{{localize "CYBER_BLUE.Sheet.Labels.Roll"}}</span>
          </div>
          {{#each skills as |skill|}}
            <div class="skill-row" data-skill-row data-skill-slug="{{skill.slug}}">
              <span class="skill-name">{{skill.label}}</span>
              <span class="skill-stat numeric-column">{{skill.statLabel}}</span>
              <input class="numeric-column" type="number" name="system.skills.{{skill.slug}}.rank" value="{{skill.rank}}" data-dtype="Number" />
              <div class="component-pill-list">
                {{#each skill.components as |component|}}
                  <button type="button" class="component-pill" data-action="roll-skill" data-skill-slug="{{../slug}}" data-component-slug="{{component.slug}}">
                    {{component.label}} ({{component.rank}})
                  </button>
                {{/each}}
              </div>
              <input class="numeric-column" type="number" value="0" data-field="modifier" />
              <button type="button" class="roll-button" data-action="roll-skill" data-skill-slug="{{skill.slug}}">
                {{localize "CYBER_BLUE.Sheet.Labels.Roll"}}
              </button>
            </div>
          {{/each}}
        </div>
      </section>

      <section class="sheet-panel component-panel">
        <div class="panel-header">
          <h2>{{localize "CYBER_BLUE.Sheet.Labels.ActorComponents"}}</h2>
          <div class="component-add">
            <select data-component-select>
              {{#each availableComponents as |component|}}
                <option value="{{component.slug}}">{{component.label}}</option>
              {{/each}}
            </select>
            <button type="button" data-action="add-component" title="{{localize "CYBER_BLUE.Sheet.Buttons.AddComponent"}}">
              <i class="fas fa-plus"></i>
            </button>
          </div>
        </div>
        {{#if components.length}}
          <div class="component-table">
            <div class="component-header component-row">
              <span>{{localize "CYBER_BLUE.Sheet.Labels.Components"}}</span>
              <span class="numeric-column">{{localize "CYBER_BLUE.Sheet.Labels.Rank"}}</span>
              <span>{{localize "CYBER_BLUE.Sheet.Labels.LinkedSkills"}}</span>
              <span></span>
            </div>
            <div class="component-entries">
              {{#each components as |component|}}
                <div class="component-row">
                  <span class="component-name">{{component.label}}</span>
                  <input class="numeric-column" type="number" name="system.components.{{component.slug}}.rank" value="{{component.rank}}" data-dtype="Number" />
                  <span class="component-links">{{component.linkedSkills}}</span>
                  <button type="button" data-action="remove-component" data-component-slug="{{component.slug}}" title="{{localize "CYBER_BLUE.Sheet.Buttons.RemoveComponent"}}">
                    <i class="fas fa-trash"></i>
                  </button>
                </div>
              {{/each}}
            </div>
          </div>
        {{else}}
          <p class="hint">No components added to this character yet.</p>
        {{/if}}
      </section>
    </div>

    <div class="tab" data-group="primary" data-tab="cyberware">
      <section class="sheet-panel">
        {{#if cyberwareGroups.length}}
          {{#each cyberwareGroups as |group|}}
            <section class="cyberware-group">
              <h2>{{group.label}}</h2>
              <div class="embedded-list">
                <div class="embedded-header embedded-row cyberware-row">
                  <span>Cyberware</span>
                  <span>{{localize "CYBER_BLUE.Sheet.Labels.Integration"}}</span>
                  <span class="numeric-column">Slots</span>
                  <span>{{localize "CYBER_BLUE.Sheet.Labels.Platform"}}</span>
                  <span>Controls</span>
                </div>
                <div class="embedded-entries">
                  {{#each group.items as |item|}}
                    <div class="embedded-entry {{#if item.isDisabled}}is-disabled{{/if}}" data-item-id="{{item.id}}" title="{{item.disabledTooltip}}">
                      <div class="embedded-row cyberware-row">
                        <button type="button" class="item-name-link embedded-name">
                          <img src="{{item.img}}" alt="{{item.name}}" />
                          <span class="embedded-name-text">
                            <span>{{item.name}}</span>
                            {{#if item.system.manufacturer}}
                              <span class="manufacturer-summary">
                                {{#if item.manufacturerLogo}}
                                  <img class="manufacturer-logo" src="{{item.manufacturerLogo}}" alt="{{item.system.manufacturer}}" />
                                {{/if}}
                                <span>{{item.system.manufacturer}}</span>
                              </span>
                            {{/if}}
                          </span>
                          {{#if item.isDisabled}}
                            <span class="state-chip state-disabled">{{localize "CYBER_BLUE.Cyberware.Disable.Label"}}</span>
                          {{/if}}
                        </button>
                        <div class="embedded-summary">{{item.integrationLabel}}</div>
                        <span class="embedded-rank numeric-column">{{item.slotText}}</span>
                        <div class="embedded-summary">{{item.platformName}}</div>
                        <div class="embedded-controls">
                          {{#if item.canDetachPlatform}}
                            <button type="button" data-action="remove-platform" title="{{localize "CYBER_BLUE.Sheet.Buttons.RemovePlatform"}}"><i class="fas fa-link-slash"></i></button>
                          {{/if}}
                          <button type="button" data-action="move-item" data-direction="up" title="{{localize "CYBER_BLUE.Sheet.Buttons.MoveUp"}}"><i class="fas fa-arrow-up"></i></button>
                          <button type="button" data-action="move-item" data-direction="down" title="{{localize "CYBER_BLUE.Sheet.Buttons.MoveDown"}}"><i class="fas fa-arrow-down"></i></button>
                          <button type="button" data-action="edit-item" title="{{localize "CYBER_BLUE.Sheet.Buttons.Edit"}}"><i class="fas fa-pen"></i></button>
                          <button type="button" data-action="delete-item" title="{{localize "CYBER_BLUE.Sheet.Buttons.Delete"}}"><i class="fas fa-trash"></i></button>
                        </div>
                      </div>
                      {{#if item.description}}
                        <div class="embedded-description">{{{item.description}}}</div>
                      {{/if}}
                    </div>
                  {{/each}}
                </div>
              </div>
            </section>
          {{/each}}
        {{else}}
          <p class="hint">No installed cyberware on this actor yet.</p>
        {{/if}}

        <section class="cyberware-group">
          <h2>{{localize "CYBER_BLUE.Cyberware.Unconnected"}}</h2>
          {{#if unconnectedCyberware.length}}
            <div class="embedded-list">
              <div class="embedded-header embedded-row cyberware-row">
                <span>Cyberware</span>
                <span>{{localize "CYBER_BLUE.Sheet.Labels.Integration"}}</span>
                <span class="numeric-column">Slots</span>
                <span>{{localize "CYBER_BLUE.Sheet.Labels.Platform"}}</span>
                <span>Controls</span>
              </div>
              <div class="embedded-entries">
                {{#each unconnectedCyberware as |item|}}
                  <div class="embedded-entry {{#if item.isDisabled}}is-disabled{{/if}}" data-item-id="{{item.id}}" title="{{item.disabledTooltip}}">
                    <div class="embedded-row cyberware-row">
                      <button type="button" class="item-name-link embedded-name">
                        <img src="{{item.img}}" alt="{{item.name}}" />
                        <span class="embedded-name-text">
                          <span>{{item.name}}</span>
                          {{#if item.system.manufacturer}}
                            <span class="manufacturer-summary">
                              {{#if item.manufacturerLogo}}
                                <img class="manufacturer-logo" src="{{item.manufacturerLogo}}" alt="{{item.system.manufacturer}}" />
                              {{/if}}
                              <span>{{item.system.manufacturer}}</span>
                            </span>
                          {{/if}}
                        </span>
                        {{#if item.isDisabled}}
                          <span class="state-chip state-disabled">{{localize "CYBER_BLUE.Cyberware.Disable.Label"}}</span>
                        {{/if}}
                      </button>
                      <div class="embedded-summary">{{item.integrationLabel}}</div>
                      <span class="embedded-rank numeric-column">{{item.slotText}}</span>
                      <div class="embedded-summary">{{localize "CYBER_BLUE.Cyberware.Unassigned"}}</div>
                      <div class="embedded-controls">
                        <button type="button" data-action="assign-platform" title="{{localize "CYBER_BLUE.Sheet.Buttons.AssignPlatform"}}" {{#unless item.hasEligiblePlatforms}}disabled{{/unless}}><i class="fas fa-link"></i></button>
                        <button type="button" data-action="move-item" data-direction="up" title="{{localize "CYBER_BLUE.Sheet.Buttons.MoveUp"}}"><i class="fas fa-arrow-up"></i></button>
                        <button type="button" data-action="move-item" data-direction="down" title="{{localize "CYBER_BLUE.Sheet.Buttons.MoveDown"}}"><i class="fas fa-arrow-down"></i></button>
                        <button type="button" data-action="edit-item" title="{{localize "CYBER_BLUE.Sheet.Buttons.Edit"}}"><i class="fas fa-pen"></i></button>
                        <button type="button" data-action="delete-item" title="{{localize "CYBER_BLUE.Sheet.Buttons.Delete"}}"><i class="fas fa-trash"></i></button>
                      </div>
                    </div>
                    {{#if item.description}}
                      <div class="embedded-description">{{{item.description}}}</div>
                    {{/if}}
                  </div>
                {{/each}}
              </div>
            </div>
          {{else}}
            <p class="hint">{{localize "CYBER_BLUE.Cyberware.NoUnconnected"}}</p>
          {{/if}}
        </section>
      </section>
    </div>

    <div class="tab" data-group="primary" data-tab="inventory">
      <section class="sheet-panel">
        <div class="panel-header panel-actions">
          <span></span>
          <button type="button" data-action="create-item" data-item-type="gear" title="{{localize "CYBER_BLUE.Sheet.Buttons.AddGear"}}">
            <i class="fas fa-plus"></i>
          </button>
        </div>

        {{#each inventoryGroups as |group|}}
          <section class="inventory-group">
            <h2>{{group.label}}</h2>
            {{#if group.items.length}}
              <div class="embedded-list inventory-list">
                <div class="embedded-header embedded-row inventory-row">
                  <span>Item</span>
                  <span class="numeric-column">{{localize "CYBER_BLUE.Sheet.Labels.Quantity"}}</span>
                  <span>{{localize "CYBER_BLUE.Sheet.Labels.Details"}}</span>
                  <span class="numeric-column">Controls</span>
                </div>
                <div class="embedded-entries">
                  {{#each group.items as |item|}}
                    <div class="embedded-row inventory-row" data-item-id="{{item.id}}">
                      <button type="button" class="item-name-link embedded-name">
                        <img src="{{item.img}}" alt="{{item.name}}" />
                        <span class="embedded-name-text">
                          <span>{{item.name}}</span>
                          {{#if item.system.manufacturer}}
                            <span class="manufacturer-summary">
                              {{#if item.manufacturerLogo}}
                                <img class="manufacturer-logo" src="{{item.manufacturerLogo}}" alt="{{item.system.manufacturer}}" />
                              {{/if}}
                              <span>{{item.system.manufacturer}}</span>
                            </span>
                          {{/if}}
                        </span>
                      </button>
                      <input class="numeric-column" type="number" value="{{item.system.quantity}}" data-action="update-item-field" data-field-path="system.quantity" data-dtype="Number" />
                      <div class="embedded-summary">
                        {{#if item.system.note}}
                          <div class="embedded-note">{{item.system.note}}</div>
                        {{/if}}
                        {{#if item.system.cost}}
                          <div>{{item.system.cost}}</div>
                        {{/if}}
                        {{#if item.armorText}}
                          <div>{{localize "CYBER_BLUE.Sheet.Labels.StoppingPower"}}: {{item.armorText}}</div>
                        {{/if}}
                        {{#each item.weaponSummaries as |weapon|}}
                          {{#if weapon.ammoText}}
                            <div>{{weapon.label}}: {{weapon.ammoText}}</div>
                          {{/if}}
                        {{/each}}
                      </div>
                      <div class="embedded-controls">
                        <button type="button" data-action="set-gear-state" data-state="equipped" title="{{localize "CYBER_BLUE.Sheet.Buttons.Equip"}}"><i class="fas fa-shield-halved"></i></button>
                        <button type="button" data-action="set-gear-state" data-state="carried" title="{{localize "CYBER_BLUE.Sheet.Buttons.Bring"}}"><i class="fas fa-briefcase"></i></button>
                        <button type="button" data-action="set-gear-state" data-state="owned" title="{{localize "CYBER_BLUE.Sheet.Buttons.Leave"}}"><i class="fas fa-house"></i></button>
                        <button type="button" data-action="move-item" data-direction="up" title="{{localize "CYBER_BLUE.Sheet.Buttons.MoveUp"}}"><i class="fas fa-arrow-up"></i></button>
                        <button type="button" data-action="move-item" data-direction="down" title="{{localize "CYBER_BLUE.Sheet.Buttons.MoveDown"}}"><i class="fas fa-arrow-down"></i></button>
                        <button type="button" data-action="edit-item" title="{{localize "CYBER_BLUE.Sheet.Buttons.Edit"}}"><i class="fas fa-pen"></i></button>
                        <button type="button" data-action="delete-item" title="{{localize "CYBER_BLUE.Sheet.Buttons.Delete"}}"><i class="fas fa-trash"></i></button>
                      </div>
                    </div>
                  {{/each}}
                </div>
              </div>
            {{else}}
              <p class="hint">{{localize "CYBER_BLUE.Sheet.Labels.NoItemsInState" state=group.label}}</p>
            {{/if}}
          </section>
        {{/each}}
      </section>
    </div>

    <div class="tab" data-group="primary" data-tab="notes">
      <section class="notes-grid">
        <div class="sheet-panel note-panel">
          <h2>{{localize "CYBER_BLUE.Sheet.Labels.Background"}}</h2>
          {{#if editable}}
            <prose-mirror name="system.details.background" value="{{system.details.background}}" document-uuid="{{actor.uuid}}" compact>
              {{{enrichedDetails.background}}}
            </prose-mirror>
          {{else}}
            <div class="editor">
              <div class="editor-content">{{{enrichedDetails.background}}}</div>
            </div>
          {{/if}}
        </div>
        <div class="sheet-panel note-panel">
          <h2>{{localize "CYBER_BLUE.Sheet.Labels.Appearance"}}</h2>
          {{#if editable}}
            <prose-mirror name="system.details.appearance" value="{{system.details.appearance}}" document-uuid="{{actor.uuid}}" compact>
              {{{enrichedDetails.appearance}}}
            </prose-mirror>
          {{else}}
            <div class="editor">
              <div class="editor-content">{{{enrichedDetails.appearance}}}</div>
            </div>
          {{/if}}
        </div>
        <div class="sheet-panel note-panel">
          <h2>{{localize "CYBER_BLUE.Sheet.Labels.Personality"}}</h2>
          {{#if editable}}
            <prose-mirror name="system.details.personality" value="{{system.details.personality}}" document-uuid="{{actor.uuid}}" compact>
              {{{enrichedDetails.personality}}}
            </prose-mirror>
          {{else}}
            <div class="editor">
              <div class="editor-content">{{{enrichedDetails.personality}}}</div>
            </div>
          {{/if}}
        </div>
        <div class="sheet-panel note-panel">
          <h2>{{localize "CYBER_BLUE.Sheet.Labels.Style"}}</h2>
          {{#if editable}}
            <prose-mirror name="system.details.style" value="{{system.details.style}}" document-uuid="{{actor.uuid}}" compact>
              {{{enrichedDetails.style}}}
            </prose-mirror>
          {{else}}
            <div class="editor">
              <div class="editor-content">{{{enrichedDetails.style}}}</div>
            </div>
          {{/if}}
        </div>
      </section>
    </div>
  </section>
</form>
