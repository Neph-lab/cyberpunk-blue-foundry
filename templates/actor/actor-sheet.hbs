<form class="{{cssClass}} {{actor.type}} flexcol" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Name" />
      </h1>
      <div class="header-stats {{#if charCreation.highlightStats}}char-creation-highlight{{/if}}">
        {{#each stats as |stat|}}
          <label class="header-stat" title="{{stat.label}}">
            <span class="stat-short">{{stat.shortLabel}}</span>
            <input type="number" name="system.stats.{{stat.slug}}.value" value="{{stat.value}}" data-dtype="Number" {{#unless ../charCreation.statsWritable}}disabled{{/unless}} />
          </label>
        {{/each}}
      </div>
    </div>
  </header>

  {{#if charCreation.active}}
    <div class="cc-sheet-banner">
      <i class="fas fa-user-plus"></i>
      <span>{{localize "CYBER_BLUE.CC.Active"}}</span>
      <button type="button" data-action="open-character-creation-wizard">
        {{localize "CYBER_BLUE.CC.Button.Open"}}
      </button>
    </div>
  {{else if charCreation.canBegin}}
    <div class="cc-sheet-banner cc-begin-banner">
      <button type="button" data-action="begin-character-creation">
        <i class="fas fa-user-plus"></i> {{localize "CYBER_BLUE.CC.Button.Begin"}}
      </button>
    </div>
  {{/if}}

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="overview">{{localize "CYBER_BLUE.Sheet.Tabs.Overview"}}</a>
    <a class="item" data-tab="skills">{{localize "CYBER_BLUE.Sheet.Tabs.Skills"}}</a>
    <a class="item" data-tab="cyberware">{{localize "CYBER_BLUE.Sheet.Tabs.Cyberware"}}</a>
    <a class="item" data-tab="inventory">{{localize "CYBER_BLUE.Sheet.Tabs.Inventory"}}</a>
    {{#if showNetrunningTab}}
      <a class="item" data-tab="netrunning">{{localize "CYBER_BLUE.Sheet.Tabs.Netrunning"}}</a>
    {{/if}}
    <a class="item" data-tab="notes">{{localize "CYBER_BLUE.Sheet.Tabs.Notes"}}</a>
  </nav>

  <section class="sheet-body">
    <div class="tab active" data-group="primary" data-tab="overview">
      <section class="sheet-panel health-panel {{#if charCreation.highlightSecondary}}char-creation-highlight{{/if}}">
        <h2>{{localize "CYBER_BLUE.Sheet.Labels.Health"}}</h2>
        <div class="health-grid">
          <div class="health-block health-hp">
            <h3>HP</h3>
            <div class="resource-fields">
              <input type="number" name="system.resources.hp.value" value="{{health.hp.value}}" data-dtype="Number" />
              <span>/</span>
              <input type="number" value="{{health.hp.max}}" disabled />
            </div>
          </div>

          <div class="health-block health-threshold">
            <h3>{{localize "CYBER_BLUE.Sheet.Labels.SeriousWoundThreshold"}}</h3>
            <div class="health-value">{{health.seriousWoundThreshold}}</div>
          </div>

          <div class="health-block health-threshold">
            <h3>{{localize "CYBER_BLUE.Sheet.Labels.DeathSave"}}</h3>
            <div class="health-value">{{health.deathSave}}</div>
          </div>

          {{#if isNPC}}
            <div class="health-block">
              <h3>{{psyche.label}}</h3>
              <div class="resource-fields">
                <input type="number" name="system.resources.psyche.value" value="{{psyche.value}}" data-dtype="Number" />
                <span>/</span>
                <input type="number" value="{{psyche.max}}" disabled />
              </div>
            </div>
          {{/if}}

          <div class="health-block health-effects">
            <h3>{{localize "CYBER_BLUE.Sheet.Labels.HealthEffects"}}</h3>
            <div class="health-effects-list">
              {{#if health.effects.length}}
                {{#each health.effects as |effect|}}
                  <div class="health-effect-row {{#if effect.isCriticalInjury}}is-critical-injury{{/if}} {{#if effect.mortal}}is-mortal{{/if}}">
                    <button type="button" class="health-effect" data-action="open-health-effect" data-effect-id="{{effect.id}}" title="{{#if effect.canEdit}}Open and edit effect{{else}}Open effect{{/if}}">
                      <img src="{{effect.icon}}" alt="{{effect.name}}" />
                      <span>{{effect.name}}</span>
                      {{#if effect.duration}}
                        <span class="effect-duration">{{effect.duration}}</span>
                      {{/if}}
                      {{#if effect.mortal}}
                        <span class="effect-mortal-badge" title="{{localize 'CYBER_BLUE.CriticalInjury.MortalWound'}}"><i class="fas fa-heart-pulse"></i></span>
                      {{/if}}
                    </button>
                    {{#if (and @root.isGM effect.isCriticalInjury)}}
                      <button type="button" class="health-effect-delete" data-action="remove-critical-injury" data-effect-id="{{effect.id}}" title="{{localize 'CYBER_BLUE.CriticalInjury.Remove'}}">
                        <i class="fas fa-trash"></i>
                      </button>
                    {{/if}}
                    {{#if (and @root.isGM effect.isAffliction)}}
                      <button type="button" class="health-effect-delete" data-action="remove-affliction" data-effect-id="{{effect.id}}" title="{{localize 'CYBER_BLUE.Combat.AfflictionRemove'}}">
                        <i class="fas fa-trash"></i>
                      </button>
                    {{/if}}
                  </div>
                {{/each}}
              {{else}}
                <p class="hint">No direct health effects on this character.</p>
              {{/if}}
            </div>
          </div>
        </div>
      </section>


<section class="quick-stats-row {{#if charCreation.highlightSecondary}}char-creation-highlight{{/if}}">
        <div class="sheet-panel stat-card armor-card">
          <span class="stat-short">{{localize "CYBER_BLUE.Sheet.Labels.StoppingPower"}}</span>
          <select name="system.combat.activeArmorItemId">
            {{#if armor.options.length}}
              {{#each armor.options as |option|}}
                <option value="{{option.id}}" {{#if (eq option.id ../armor.activeId)}}selected{{/if}}>{{option.name}}</option>
              {{/each}}
            {{else}}
              <option value="">{{localize "CYBER_BLUE.Sheet.Labels.NoArmor"}}</option>
            {{/if}}
          </select>
          <div class="resource-fields">
            <input type="number" value="{{armor.current}}" disabled />
            <span>/</span>
            <input type="number" value="{{armor.max}}" disabled />
          </div>
        </div>

        {{#unless isNPC}}
          <label class="sheet-panel stat-card move-card">
            <span class="stat-short">{{move.shortLabel}}</span>
            <input type="number" name="system.stats.move.value" value="{{move.value}}" data-dtype="Number" />
          </label>
        {{/unless}}

        {{#if isNPC}}
          <div class="sheet-panel stat-card move-card">
            <span class="stat-short">{{psyche.label}}</span>
            <div class="resource-fields">
              <input type="number" name="system.resources.psyche.value" value="{{psyche.value}}" data-dtype="Number" />
              <span>/</span>
              <input type="number" value="{{psyche.max}}" disabled />
            </div>
          </div>
        {{else}}
          <div class="sheet-panel stat-card move-card">
            <span class="stat-short">{{psyche.label}}</span>
            <div class="resource-fields">
              <input type="number" name="system.resources.psyche.value" value="{{psyche.value}}" data-dtype="Number" />
              <span>/</span>
              <input type="number" value="{{psyche.max}}" disabled />
            </div>
          </div>

          <div class="sheet-panel stat-card move-card luck-card">
            <span class="stat-short">{{luck.label}}</span>
            <div class="resource-fields">
              <input type="number" name="system.resources.luck.value" value="{{luck.value}}" data-dtype="Number" />
              <span>/</span>
              <input type="number" value="{{luck.max}}" disabled />
            </div>
          </div>
        {{/if}}

        <div class="sheet-panel stat-card money-card">
          <span class="stat-short">€$</span>
          <input type="text" data-action="update-money" value="{{system.money}}" placeholder="0" title="Eurobucks — arithmetic OK (e.g. 500-50)" style="width:5rem;text-align:right;" />
        </div>
      </section>

      {{#if combatWeapons.length}}
        <section class="sheet-panel combat-weapon-panel">
          <table class="embedded-table combat-weapon-table">
            <colgroup>
              <col />
              <col class="column-compact" />
              <col class="column-compact" />
              <col />
              <col class="column-compact" />
              <col class="column-compact" />
              <col class="column-compact" />
              <col class="column-compact" />
              <col class="column-controls" />
            </colgroup>
            <thead>
              <tr>
                <th>Weapon</th>
                <th class="numeric-column">{{localize "CYBER_BLUE.Sheet.Labels.Attack"}}</th>
                <th class="numeric-column" title="{{localize 'CYBER_BLUE.Combat.TargetVitals'}}"><i class="fas fa-crosshairs"></i></th>
                <th>{{localize "CYBER_BLUE.Sheet.Labels.WeaponSkill"}}</th>
                <th class="numeric-column">{{localize "CYBER_BLUE.Sheet.Labels.Damage"}}</th>
                <th class="numeric-column">{{localize "CYBER_BLUE.Sheet.Labels.RateOfFire"}}</th>
                <th class="numeric-column">{{localize "CYBER_BLUE.Sheet.Labels.Mag"}}</th>
                <th class="numeric-column" title="{{localize "CYBER_BLUE.Sheet.Labels.Concealable"}}"><i class="fas fa-eye-slash"></i></th>
                <th class="numeric-column">Controls</th>
              </tr>
            </thead>
            <tbody>
              {{#each combatWeapons as |weapon|}}
                <tr data-item-id="{{weapon.itemId}}">
                  <td>
                    <button type="button" class="item-name-link embedded-name">
                      <span>{{weapon.name}}</span>
                    </button>
                    {{#if weapon.modDots.length}}
                      <span class="weapon-mod-dots">
                        {{#each weapon.modDots}}
                          <i class="fas fa-circle weapon-mod-dot"></i>
                        {{/each}}
                      </span>
                    {{/if}}
                  </td>
                  <td class="numeric-column">
                    <button type="button" data-action="weapon-attack" data-weapon-index="{{weapon.weaponIndex}}" title="{{weapon.attackTooltip}}" {{#if weapon.attackDisabled}}disabled{{/if}} {{#if weapon.jammed}}disabled{{/if}}>
                      {{#if weapon.isAffliction}}<i class="fas fa-biohazard"></i> {{localize "CYBER_BLUE.Combat.AfflictionAttackLabel"}}{{else}}{{localize "CYBER_BLUE.Combat.Attack"}}{{/if}} ({{weapon.attackLabel}}){{#if weapon.rofExhausted}} ✗{{/if}}{{#if weapon.jammed}} <i class="fas fa-exclamation-triangle"></i>{{/if}}
                    </button>
                    {{#if weapon.hasAutofire}}
                      <button type="button" data-action="weapon-autofire" data-weapon-index="{{weapon.weaponIndex}}" title="{{weapon.autofireTooltip}}" {{#unless weapon.autofireAmmoOk}}disabled{{/unless}} {{#if weapon.attackDisabled}}disabled{{/if}}>
                        {{localize "CYBER_BLUE.Combat.Autofire"}} ({{weapon.autofireLabel}})
                      </button>
                    {{/if}}
                    {{#if weapon.hasDoubleLock}}
                      <button type="button" data-action="weapon-double-lock" data-weapon-index="{{weapon.weaponIndex}}" title="{{localize 'CYBER_BLUE.Combat.DoubleLockHint'}}" {{#unless weapon.doubleLockAmmoOk}}disabled{{/unless}} {{#if weapon.attackDisabled}}disabled{{/if}}>
                        <i class="fas fa-crosshairs"></i> {{localize "CYBER_BLUE.Combat.DoubleLock"}}
                      </button>
                    {{/if}}
                  </td>
                  <td class="numeric-column target-vitals-cell">
                    {{#if weapon.isStandardDamage}}
                      <label class="target-vitals-label" title="{{localize 'CYBER_BLUE.Combat.TargetVitalsHint'}}">
                        <input type="checkbox" data-action="toggle-target-vitals" data-weapon-index="{{weapon.weaponIndex}}" {{#if weapon.targetVitals}}checked{{/if}} />
                      </label>
                    {{/if}}
                  </td>
                  <td>
                    {{#if weapon.skillOptions.length}}
                      <select data-action="update-item-field" data-field-path="system.weapons.{{weapon.weaponIndex}}.skill">
                        {{#each weapon.skillOptions as |option|}}
                          <option value="{{option.value}}" {{#if (eq option.value ../skillSlug)}}selected{{/if}}>{{option.label}}</option>
                        {{/each}}
                      </select>
                    {{else}}
                      <span>{{weapon.skillSlug}}</span>
                    {{/if}}
                  </td>
                  <td class="numeric-column">
                    <button type="button" data-action="weapon-damage" data-weapon-index="{{weapon.weaponIndex}}" title="{{localize "CYBER_BLUE.Sheet.Buttons.RollDamage"}}">
                      {{weapon.damage}}
                    </button>
                  </td>
                  <td class="numeric-column" title="{{localize "CYBER_BLUE.Combat.RateOfFireTitle"}}">{{#if weapon.attacksUsed}}{{weapon.attacksUsed}}/{{/if}}{{weapon.rateOfFire}}</td>
                  <td class="numeric-column">
                    {{#if weapon.showsAmmo}}
                      <div class="resource-fields compact-resource">
                        <input type="number" value="{{weapon.ammoCurrent}}" data-action="update-item-field" data-field-path="system.weapons.{{weapon.weaponIndex}}.ammoCurrent" data-dtype="Number" />
                        <span>/</span>
                        <input type="number" value="{{weapon.magazine}}" disabled />
                      </div>
                    {{else}}
                      <span>&mdash;</span>
                    {{/if}}
                  </td>
                  <td class="numeric-column">
                    {{#if weapon.concealable}}
                      <i class="fas fa-eye-slash" title="{{localize "CYBER_BLUE.Sheet.Labels.Concealable"}}"></i>
                    {{/if}}
                  </td>
                  <td class="numeric-column">
                    {{#if weapon.showsAmmo}}
                      <button type="button" data-action="weapon-reload" data-weapon-index="{{weapon.weaponIndex}}" data-magazine="{{weapon.magazine}}" title="{{localize "CYBER_BLUE.Sheet.Buttons.Reload"}}">
                        <i class="fas fa-rotate-right"></i>
                      </button>
                    {{/if}}
                    {{#if weapon.jammed}}
                      <button type="button" class="weapon-unjam-btn" data-action="weapon-unjam" data-weapon-index="{{weapon.weaponIndex}}" title="{{localize 'CYBER_BLUE.Combat.WeaponUnjamHint'}}">
                        <i class="fas fa-wrench"></i>
                      </button>
                    {{/if}}
                    {{#if weapon.hasCalibration}}
                      <button type="button" class="weapon-calibrate-btn{{#if weapon.calibrationActive}} calibration-active{{/if}}" data-action="weapon-calibrate" data-weapon-index="{{weapon.weaponIndex}}" title="{{localize 'CYBER_BLUE.Combat.CalibrateHint'}}">
                        <i class="fas fa-bullseye"></i>
                      </button>
                    {{/if}}
                    {{#if weapon.isPowerWeapon}}
                      <button type="button" class="weapon-ricochet-btn{{#if weapon.ricochetActive}} ricochet-active{{/if}}" data-action="weapon-ricochet" data-weapon-index="{{weapon.weaponIndex}}" title="{{localize 'CYBER_BLUE.Combat.RicochetHint'}}">
                        <i class="fas fa-circle-dot"></i>
                      </button>
                    {{/if}}
                    {{#if weapon.isTechWeapon}}
                      <button type="button" class="weapon-charge-btn{{#if weapon.isCharged}} charge-active{{/if}}{{#if weapon.isChargeCooldown}} charge-cooldown{{/if}}" data-action="weapon-charge" data-weapon-index="{{weapon.weaponIndex}}" {{#if weapon.chargeDisabled}}disabled{{/if}} title="{{localize 'CYBER_BLUE.Combat.ChargeHint'}}">
                        <i class="fas fa-bolt-lightning"></i>
                      </button>
                    {{/if}}
                    {{#if weapon.hasElectricCharge}}
                      <span class="electric-charge-indicator{{#if (eq weapon.electricChargeUses 0)}} depleted{{/if}}" title="{{localize 'CYBER_BLUE.Combat.ElectricChargeTitle'}}">
                        <i class="fas fa-battery-{{#if (eq weapon.electricChargeUses 0)}}empty{{else}}full{{/if}}"></i> {{weapon.electricChargeUses}}/{{weapon.electricChargeMax}}
                      </span>
                    {{/if}}
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </section>
      {{/if}}

      {{#if martialArtsAttacks.length}}
        {{> "systems/cyberpunk-blue/templates/actor/parts/actor-martial-arts.hbs"}}
      {{/if}}

      {{#if enrichedRoleOverviewFeatures.length}}
        <section class="sheet-panel role-overview-panel">
          {{#each enrichedRoleOverviewFeatures as |feature|}}
            <section class="role-overview-feature" data-item-id="{{feature.roleId}}">
              <h4 class="roleCategory">{{feature.roleName}}</h4>
              {{#unless (eq feature.kind "protean")}}
                {{#if feature.sections.length}}
                  {{#each feature.sections as |section|}}
                    <div class="role-overview-html">{{{section.enrichedContent}}}</div>
                  {{/each}}
                {{/if}}
              {{/unless}}
              {{#if (eq feature.kind "protean")}}
                <div class="role-focus-summary">
                  <span>{{localize "CYBER_BLUE.Role.Pool"}}: {{feature.totalPoints}}</span>
                  <span>{{localize "CYBER_BLUE.Role.Remaining"}}: {{feature.remainingPoints}}</span>
                </div>
                <div class="protean-tactic-list">
                  {{#each feature.foci as |focus|}}
                    <div class="protean-tactic" data-item-id="{{../roleId}}">
                      <div class="protean-tactic-name">{{focus.name}}</div>
                      {{#if focus.description}}
                        <div class="protean-tactic-description">{{focus.description}}</div>
                      {{/if}}
                      <div class="protean-tactic-points">
                        <div class="protean-radio-group">
                          {{#each focus.pointOptions as |option|}}
                            <label class="protean-radio {{#if option.disabled}}is-disabled{{/if}}">
                              <input type="radio" name="protean-tactic-{{../focusIndex}}" value="{{option.value}}" {{#if (eq option.value ../points)}}checked{{/if}} {{#if option.disabled}}disabled{{/if}} data-action="update-protean-points" data-focus-index="{{../focusIndex}}" />
                              <span>{{option.value}}</span>
                            </label>
                          {{/each}}
                        </div>
                      </div>
                    </div>
                  {{/each}}
                </div>
              {{/if}}
              {{#if (eq feature.kind "leader")}}
                {{#each feature.leaderFeatures as |leaderFeature|}}
                  <div class="role-leader-feature">
                    <h5>{{leaderFeature.name}}</h5>
                    {{#if leaderFeature.description}}
                      <p class="hint">{{leaderFeature.description}}</p>
                    {{/if}}
                    <div class="team-member-list">
                      {{#each leaderFeature.members as |member|}}
                        <button type="button" class="item-name-link embedded-name team-member-link" data-action="open-team-member" data-actor-id="{{member.id}}">
                          <img src="{{member.img}}" alt="{{member.name}}" />
                          <span>{{member.name}}</span>
                        </button>
                      {{/each}}
                    </div>
                  </div>
                {{/each}}
              {{/if}}
              {{#if (eq feature.kind "specialist")}}
                <div class="specialty-summary-list">
                  {{#each feature.specialties as |specialty|}}
                    <div class="specialty-summary">
                      <strong>{{specialty.name}}</strong>
                      <span>{{localize "CYBER_BLUE.Sheet.Labels.Rank"}} {{specialty.rank}}</span>
                      {{#each specialty.unlockedSections as |section|}}
                        <div class="role-overview-html">{{{section.enrichedContent}}}</div>
                      {{/each}}
                      {{#if specialty.allOptions.length}}
                        <div class="specialty-options">
                          {{#each specialty.allOptions as |opt|}}
                            <label class="checkbox {{#if opt.disabled}}is-disabled{{/if}}" title="{{opt.description}}" data-item-id="{{../../roleId}}">
                              <input type="checkbox"
                                data-action="toggle-specialty-option"
                                data-specialty-index="{{../specialtyIndex}}"
                                data-group-index="{{opt.groupIndex}}"
                                data-option-id="{{opt.id}}"
                                {{checked opt.selected}}
                                {{#if opt.disabled}}disabled{{/if}} />
                              <span>{{opt.name}}</span>
                            </label>
                          {{/each}}
                        </div>
                      {{/if}}
                    </div>
                  {{/each}}
                </div>
              {{/if}}

              {{!-- ── Role-specific mechanics ── --}}
              {{#if feature.hasMechanics}}
                <div class="role-mechanics-panel">
                  {{!-- Netrunner: NET Actions --}}
                  {{#if feature.roleMechanics.netActionsTotal}}
                    <div class="role-mechanic-row role-net-actions">
                      <span class="role-mechanic-label">{{localize "CYBER_BLUE.Role.Netrunner.NetActions"}}</span>
                      <span class="role-mechanic-value">{{feature.roleMechanics.netActionsTotal}}</span>
                    </div>
                  {{/if}}

                  {{!-- Bandit: Tough --}}
                  {{#if feature.roleMechanics.toughMaxUses}}
                    <div class="role-mechanic-row role-tough-row">
                      <button type="button" data-action="role-bandit-tough" class="role-action-btn {{#if feature.roleMechanics.toughDepleted}}is-depleted{{/if}}" {{#if feature.roleMechanics.toughDepleted}}disabled{{/if}}>
                        <i class="fas fa-fist-raised"></i>
                        {{localize "CYBER_BLUE.Role.Bandit.Tough"}}
                      </button>
                      <span class="role-mechanic-uses">{{feature.roleMechanics.toughUsesRemaining}} / {{feature.roleMechanics.toughMaxUses}}</span>
                      <button type="button" data-action="role-bandit-tough-reset" class="role-action-btn role-reset-btn" title="{{localize "CYBER_BLUE.Role.Bandit.ToughResetTitle"}}">
                        <i class="fas fa-redo"></i>
                      </button>
                    </div>
                  {{/if}}

                  {{!-- Media: Rumour pickup --}}
                  {{#if feature.roleMechanics.canPickUpRumours}}
                    <div class="role-mechanic-row role-rumour-row">
                      <span class="role-mechanic-label">{{localize "CYBER_BLUE.Role.Media.PickUpRumours"}}</span>
                      <div class="role-rumour-tiers">
                        {{#each feature.roleMechanics.rumourDvs as |tier|}}
                          <div class="role-rumour-tier">
                            <span class="role-mechanic-label">{{localize tier.label}}</span>
                            <button type="button" data-action="role-media-rumour" data-dv-type="passive" data-dv="{{tier.passiveDv}}" data-tier-name="{{localize tier.label}}" class="role-action-btn role-action-btn-sm">
                              <i class="fas fa-ear-listen"></i> P{{tier.passiveDv}}
                            </button>
                            <button type="button" data-action="role-media-rumour" data-dv-type="active" data-dv="{{tier.activeDv}}" data-tier-name="{{localize tier.label}}" class="role-action-btn role-action-btn-sm">
                              <i class="fas fa-newspaper"></i> A{{tier.activeDv}}
                            </button>
                          </div>
                        {{/each}}
                      </div>
                    </div>
                  {{/if}}

                  {{!-- Rocker: Rock --}}
                  {{#if feature.roleMechanics.canRock}}
                    <div class="role-mechanic-row role-rock-row">
                      <button type="button" data-action="role-rocker-rock" class="role-action-btn">
                        <i class="fas fa-guitar"></i>
                        {{localize "CYBER_BLUE.Role.Rocker.Rock"}}
                      </button>
                    </div>
                  {{/if}}

                  {{!-- Law: Call Backup --}}
                  {{#if feature.roleMechanics.backupTypes}}
                    <div class="role-mechanic-row role-backup-row">
                      <span class="role-mechanic-label">{{localize "CYBER_BLUE.Role.Law.CallBackup"}}</span>
                      <div class="role-backup-buttons">
                        {{#each feature.roleMechanics.backupTypes as |bt|}}
                          <button type="button" data-action="role-law-backup" data-backup-type="{{bt.name}}" data-dv="{{bt.dv}}" class="role-action-btn">
                            <i class="fas fa-siren"></i>
                            {{bt.name}} (DV {{bt.dv}})
                          </button>
                        {{/each}}
                      </div>
                    </div>
                  {{/if}}

                  {{!-- Medtech: Patch Up / Surgery / Cryo --}}
                  {{#if feature.roleMechanics.canPatchUp}}
                    <div class="role-mechanic-row role-medtech-row">
                      <button type="button" data-action="role-medtech-patchup" class="role-action-btn">
                        <i class="fas fa-kit-medical"></i>
                        {{localize "CYBER_BLUE.Role.Medtech.PatchUp"}} (max {{feature.roleMechanics.patchUpMaxHp}} HP)
                      </button>
                    </div>
                  {{/if}}
                  {{#if feature.roleMechanics.canSurgery}}
                    <div class="role-mechanic-row role-medtech-row">
                      <button type="button" data-action="role-medtech-surgery" class="role-action-btn">
                        <i class="fas fa-scalpel"></i>
                        {{localize "CYBER_BLUE.Role.Medtech.Surgery"}}
                      </button>
