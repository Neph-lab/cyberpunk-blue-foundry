                          <button type="button" data-action="start-instructions" title="{{item.instructionNextLabel}}">{{localize "CYBER_BLUE.Instructions.Use"}}</button>
                        {{else}}
                          <span class="hint">{{localize "CYBER_BLUE.Instructions.EmptyQuantity"}}</span>
                        {{/if}}
                      {{/if}}
                    </div>
                    <div class="embedded-controls">
                      <button type="button" data-action="edit-item" title="{{localize "CYBER_BLUE.Sheet.Buttons.Edit"}}"><i class="fas fa-pen"></i></button>
                      <button type="button" data-action="delete-item" title="{{localize "CYBER_BLUE.Sheet.Buttons.Delete"}}"><i class="fas fa-trash"></i></button>
                    </div>
                  </div>
                {{/each}}
              </div>
            </div>
          </section>
        {{/if}}
      </section>
    </div>

    {{#if showNetrunningTab}}
      <div class="tab" data-group="primary" data-tab="netrunning">

        {{!-- ── Component interface boxes ── --}}
        <section class="sheet-panel">
          <h2>{{localize "CYBER_BLUE.Combat.NetrunnerComponents"}}</h2>
          <div class="netrunner-components-row">
            {{#each netrunnerComponents as |comp|}}
              <div class="netrunner-component-box">
                <div class="netrunner-comp-header">
                  <span class="netrunner-comp-name">{{comp.label}}</span>
                  <span class="netrunner-comp-mod">{{comp.modLabel}}</span>
                </div>
                <div class="netrunner-comp-uses">
                  {{#each comp.uses as |use|}}
                    <button type="button"
                      class="netrunner-use-btn"
                      data-action="netrunner-component-roll"
                      data-component-slug="{{use.componentSlug}}"
                      data-use-label="{{use.label}}"
                      data-modifier="{{use.modifier}}"
                      title="Roll 1d10 {{use.modLabel}}">
                      {{use.label}}
                    </button>
                  {{/each}}
                </div>
              </div>
            {{/each}}
          </div>
        </section>

        {{!-- ── Connection Status ── --}}
        <section class="sheet-panel net-connection-panel">
          <div class="net-connection-row">
            {{#if netConnected}}
              <span class="state-chip net-chip-connected"><i class="fas fa-plug"></i> {{localize "CYBER_BLUE.Netrunning.Connected"}}</span>
              <button type="button" class="net-action-btn" data-action="net-disconnect">
                <i class="fas fa-plug-circle-xmark"></i> {{localize "CYBER_BLUE.Netrunning.Disconnect"}}
              </button>
            {{else}}
              <span class="state-chip net-chip-disconnected"><i class="fas fa-plug-circle-xmark"></i> {{localize "CYBER_BLUE.Netrunning.NotConnected"}}</span>
              {{#if canConnect}}
                <button type="button" class="net-action-btn" data-action="net-connect">
                  <i class="fas fa-plug"></i> {{localize "CYBER_BLUE.Netrunning.Connect"}}
                  {{#if nearbyAccessPoints.length}}({{nearbyAccessPoints.length}}){{/if}}
                </button>
              {{/if}}
            {{/if}}
            <button type="button" class="net-action-btn" data-action="net-defrag" title="{{localize "CYBER_BLUE.Netrunning.Defrag"}}">
              <i class="fas fa-broom"></i> {{localize "CYBER_BLUE.Netrunning.Defrag"}}
            </button>
          </div>
        </section>

        {{!-- ── Computers ── --}}
        <section class="sheet-panel">
          <h2>{{localize "CYBER_BLUE.Combat.NetrunnerComputers"}}</h2>
          {{#if netrunnerComputers.length}}
            <div class="netrunner-computers-list">
              {{#each netrunnerComputers as |comp|}}
                <div class="netrunner-computer-card">
                  <div class="netrunner-computer-name">
                    <img src="{{comp.img}}" class="item-img" alt="{{comp.name}}" />
                    <span>{{comp.name}}</span>
                    {{#if comp.isCyberdeck}}<span class="state-chip">Cyberdeck</span>{{/if}}
                    {{#if comp.canQuickhack}}<span class="state-chip">Quickhack</span>{{/if}}
                  </div>
                  <div class="netrunner-computer-stats">
                    {{#if comp.hardwareSlots}}<span title="Hardware Slots">HW: {{comp.hardwareSlots}}</span>{{/if}}
                    <span title="Software Slots">SW: {{comp.softwareSlots}} ({{comp.freeSlots}} free)</span>
                    {{#if comp.generalSlots}}<span title="General Slots">Gen: {{comp.generalSlots}}</span>{{/if}}
                    {{#if comp.isCyberdeck}}
                      <span title="{{localize "CYBER_BLUE.Netrunning.RamLabel"}}">
                        {{localize "CYBER_BLUE.Netrunning.RamLabel"}}: {{comp.currentRam}}/{{comp.ram}}
                      </span>
                    {{else if comp.ram}}
                      <span title="RAM">RAM: {{comp.ram}}</span>
                    {{/if}}
                    {{#if comp.range}}<span title="{{localize "CYBER_BLUE.Netrunning.RangeLabel"}}">{{localize "CYBER_BLUE.Netrunning.RangeLabel"}}: {{comp.range}}m</span>{{/if}}
                  </div>
                </div>
              {{/each}}
            </div>
          {{else}}
            <p class="hint">{{localize "CYBER_BLUE.Combat.NetrunnerNoComputers"}}</p>
          {{/if}}
        </section>

        {{!-- ── Quickhacking ── --}}
        {{#if canQuickhack}}
          <section class="sheet-panel net-quickhack-panel">
            <h2>{{localize "CYBER_BLUE.Netrunning.Breach"}}</h2>
            <div class="net-quickhack-row">
              <span class="net-qh-target">{{quickhackTarget}}</span>
              {{#if quickhackTargetBreached}}
                <span class="state-chip net-chip-breached"><i class="fas fa-skull"></i> {{localize "CYBER_BLUE.Netrunning.BreachedStatus"}}</span>
                <button type="button" class="net-action-btn" data-action="net-quickhack-upload">
                  <i class="fas fa-upload"></i> {{localize "CYBER_BLUE.Netrunning.Upload"}}
                </button>
              {{else}}
                <button type="button" class="net-action-btn" data-action="net-quickhack-breach">
                  <i class="fas fa-bolt"></i> {{localize "CYBER_BLUE.Netrunning.Breach"}}
                </button>
              {{/if}}
            </div>
          </section>
        {{/if}}

        {{!-- ── On Disk executables ── --}}
        <section class="sheet-panel">
          <h2>{{localize "CYBER_BLUE.Combat.ExecutablesOnDisk"}}</h2>
          {{#if executablesOnDisk.length}}
            <table class="netrunner-exe-table">
              <thead>
                <tr>
                  <th class="exe-name-col">Name</th>
                  {{#if diskColVis.showNote}}<th>Note</th>{{/if}}
                  {{#if diskColVis.showAct}}<th>ACT</th>{{/if}}
                  {{#if diskColVis.showAtk}}<th>ATK</th>{{/if}}
                  {{#if diskColVis.showDef}}<th>DEF</th>{{/if}}
                  {{#if diskColVis.showNet}}<th>NET</th>{{/if}}
                  {{#if diskColVis.showPer}}<th>PER</th>{{/if}}
                  {{#if diskColVis.showRez}}<th>REZ</th>{{/if}}
                  <th>Running</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {{#each executablesOnDisk as |exe|}}
                  <tr data-item-id="{{exe.id}}">
                    <td class="exe-name-col">
                      <a class="item-name-link" data-item-id="{{exe.id}}">{{exe.name}}</a>
                      {{#if exe.computerName}}<span class="hint exe-computer-name">{{exe.computerName}}</span>{{/if}}
                    </td>
                    {{#if @root.diskColVis.showNote}}<td>{{exe.system.note}}</td>{{/if}}
                    {{#if @root.diskColVis.showAct}}<td>{{#if exe.system.act}}{{exe.system.act}}{{/if}}</td>{{/if}}
                    {{#if @root.diskColVis.showAtk}}
                      <td>
                        {{#if exe.system.atk}}
                          <button type="button" class="exe-roll-btn" data-action="executable-roll-atk" data-item-id="{{exe.id}}" title="Roll 1d10+ATK">
                            {{exe.system.atk}} <i class="fas fa-dice-d10"></i>
                          </button>
                        {{/if}}
                      </td>
                    {{/if}}
                    {{#if @root.diskColVis.showDef}}<td>{{#if exe.system.def}}{{exe.system.def}}{{/if}}</td>{{/if}}
                    {{#if @root.diskColVis.showNet}}<td>{{#if exe.system.net}}{{exe.system.net}}{{/if}}</td>{{/if}}
                    {{#if @root.diskColVis.showPer}}
                      <td>
                        {{#if exe.system.per}}
                          <button type="button" class="exe-roll-btn" data-action="executable-roll-per" data-item-id="{{exe.id}}" title="Roll 1d10+PER">
                            {{exe.system.per}} <i class="fas fa-dice-d10"></i>
                          </button>
                        {{/if}}
                      </td>
                    {{/if}}
                    {{#if @root.diskColVis.showRez}}
                      <td class="exe-rez-cell">
                        <input type="number" class="exe-rez-input"
                          data-executable-field
                          data-executable-id="{{exe.id}}"
                          data-field="system.rez.value"
                          data-dtype="Number"
                          value="{{exe.system.rez.value}}"
                          min="0"
                          max="{{exe.system.rez.max}}" />
                        <span>/{{exe.system.rez.max}}</span>
                      </td>
                    {{/if}}
                    <td class="exe-running-cell">
                      <input type="checkbox"
                        data-executable-field
                        data-executable-id="{{exe.id}}"
                        data-field="system.running"
                        {{checked exe.system.running}} />
                    </td>
                    <td>
                      <button type="button" class="exe-action-btn" data-action="executable-uninstall" data-item-id="{{exe.id}}" title="{{localize "CYBER_BLUE.Sheet.Labels.UninstallExecutable"}}">
                        <i class="fas fa-eject"></i>
                      </button>
                    </td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          {{else}}
            <p class="hint">{{localize "CYBER_BLUE.Combat.NoExecutablesOnDisk"}}</p>
          {{/if}}
        </section>

        {{!-- ── On Shards executables ── --}}
        <section class="sheet-panel">
          <h2>{{localize "CYBER_BLUE.Combat.ExecutablesOnShards"}}</h2>
          {{#if executablesOnShards.length}}
            <table class="netrunner-exe-table">
              <thead>
                <tr>
                  <th class="exe-name-col">Name</th>
                  {{#if shardsColVis.showNote}}<th>Note</th>{{/if}}
                  {{#if shardsColVis.showAct}}<th>ACT</th>{{/if}}
                  {{#if shardsColVis.showAtk}}<th>ATK</th>{{/if}}
                  {{#if shardsColVis.showDef}}<th>DEF</th>{{/if}}
                  {{#if shardsColVis.showNet}}<th>NET</th>{{/if}}
                  {{#if shardsColVis.showPer}}<th>PER</th>{{/if}}
                  {{#if shardsColVis.showRez}}<th>REZ</th>{{/if}}
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {{#each executablesOnShards as |exe|}}
                  <tr data-item-id="{{exe.id}}">
                    <td class="exe-name-col">
                      <a class="item-name-link" data-item-id="{{exe.id}}">{{exe.name}}</a>
                      {{#if exe.invalidComputer}}<span class="hint ammo-type-missing">(computer not found)</span>{{/if}}
                    </td>
                    {{#if @root.shardsColVis.showNote}}<td>{{exe.system.note}}</td>{{/if}}
                    {{#if @root.shardsColVis.showAct}}<td>{{#if exe.system.act}}{{exe.system.act}}{{/if}}</td>{{/if}}
                    {{#if @root.shardsColVis.showAtk}}<td>{{#if exe.system.atk}}{{exe.system.atk}}{{/if}}</td>{{/if}}
                    {{#if @root.shardsColVis.showDef}}<td>{{#if exe.system.def}}{{exe.system.def}}{{/if}}</td>{{/if}}
                    {{#if @root.shardsColVis.showNet}}<td>{{#if exe.system.net}}{{exe.system.net}}{{/if}}</td>{{/if}}
                    {{#if @root.shardsColVis.showPer}}<td>{{#if exe.system.per}}{{exe.system.per}}{{/if}}</td>{{/if}}
                    {{#if @root.shardsColVis.showRez}}<td>{{#if exe.system.rez.max}}{{exe.system.rez.max}}{{/if}}</td>{{/if}}
                    <td>
                      <button type="button" class="exe-action-btn" data-action="executable-install" data-item-id="{{exe.id}}" title="{{localize "CYBER_BLUE.Sheet.Labels.InstallExecutable"}}">
                        <i class="fas fa-download"></i>
                      </button>
                    </td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          {{else}}
            <p class="hint">{{localize "CYBER_BLUE.Combat.NoExecutablesOnShards"}}</p>
          {{/if}}
        </section>

      </div>
    {{/if}}

    <div class="tab" data-group="primary" data-tab="notes">
      <section class="notes-grid">
        <div class="sheet-panel note-panel">
          <h2>{{localize "CYBER_BLUE.Sheet.Labels.Background"}}</h2>
          {{#if charCreation.notesWritable}}
            <prose-mirror name="system.details.background" value="{{system.details.background}}" document-uuid="{{actor.uuid}}" compact>
              {{{enrichedDetails.background}}}
            </prose-mirror>
          {{else}}
            <div class="enriched-html">{{{enrichedDetails.background}}}</div>
          {{/if}}
        </div>
        <div class="sheet-panel note-panel">
          <h2>{{localize "CYBER_BLUE.Sheet.Labels.Appearance"}}</h2>
          {{#if charCreation.notesWritable}}
            <prose-mirror name="system.details.appearance" value="{{system.details.appearance}}" document-uuid="{{actor.uuid}}" compact>
              {{{enrichedDetails.appearance}}}
            </prose-mirror>
          {{else}}
            <div class="enriched-html">{{{enrichedDetails.appearance}}}</div>
          {{/if}}
        </div>
        <div class="sheet-panel note-panel">
          <h2>{{localize "CYBER_BLUE.Sheet.Labels.Personality"}}</h2>
          {{#if charCreation.notesWritable}}
            <prose-mirror name="system.details.personality" value="{{system.details.personality}}" document-uuid="{{actor.uuid}}" compact>
              {{{enrichedDetails.personality}}}
            </prose-mirror>
          {{else}}
            <div class="enriched-html">{{{enrichedDetails.personality}}}</div>
          {{/if}}
        </div>
        <div class="sheet-panel note-panel">
          <h2>{{localize "CYBER_BLUE.Sheet.Labels.Style"}}</h2>
          {{#if charCreation.notesWritable}}
            <prose-mirror name="system.details.style" value="{{system.details.style}}" document-uuid="{{actor.uuid}}" compact>
              {{{enrichedDetails.style}}}
            </prose-mirror>
          {{else}}
            <div class="enriched-html">{{{enrichedDetails.style}}}</div>
          {{/if}}
        </div>
      </section>
    </div>
  </section>
</form>
