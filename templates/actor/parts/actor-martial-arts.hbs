{{!-- Martial Arts section for the Overview tab --}}
<section class="sheet-panel martial-arts-panel">
  <h3 class="section-header">{{localize "CYBER_BLUE.MartialArts.Title"}}</h3>

  {{!-- Attack table --}}
  <table class="embedded-table combat-weapon-table">
    <colgroup>
      <col />
      <col class="column-compact" />
      <col class="column-compact" />
      <col class="column-compact" />
      <col class="column-compact" />
      <col class="column-compact" />
    </colgroup>
    <thead>
      <tr>
        <th>{{localize "CYBER_BLUE.MartialArts.Component"}}</th>
        <th class="numeric-column">{{localize "CYBER_BLUE.Sheet.Labels.Attack"}}</th>
        <th class="numeric-column" title="{{localize 'CYBER_BLUE.Combat.TargetVitals'}}"><i class="fas fa-crosshairs"></i></th>
        <th class="numeric-column">{{localize "CYBER_BLUE.Sheet.Labels.Damage"}}</th>
        <th class="numeric-column" title="{{localize 'CYBER_BLUE.Combat.RateOfFireTitle'}}">{{localize "CYBER_BLUE.Sheet.Labels.RateOfFire"}}</th>
        <th class="numeric-column"></th>
      </tr>
    </thead>
    <tbody>
      {{#each martialArtsAttacks as |ma|}}
        <tr class="weapon-row{{#if ma.attackDisabled}} weapon-rof-locked{{/if}}">
          <td>
            {{#if ma.componentLabel}}
              {{ma.componentLabel}}
            {{else}}
              {{localize "CYBER_BLUE.MartialArts.Generic"}}
            {{/if}}
          </td>
          <td class="numeric-column">
            <button type="button"
              data-action="ma-attack"
              data-ma-index="{{ma.maIndex}}"
              data-component-slug="{{ma.componentSlug}}"
              title="{{ma.attackTooltip}}"
              {{#if ma.attackDisabled}}disabled{{/if}}>
              {{ma.attackLabel}}
            </button>
          </td>
          <td class="numeric-column">
            <input type="checkbox"
              data-action="ma-toggle-vitals"
              data-ma-index="{{ma.maIndex}}"
              {{#if ma.targetVitals}}checked{{/if}}
              title="{{localize 'CYBER_BLUE.Combat.TargetVitals'}}" />
          </td>
          <td class="numeric-column">{{ma.damage}}</td>
          <td class="numeric-column">{{#if ma.attacksUsed}}{{ma.attacksUsed}}/{{/if}}{{ma.rateOfFire}}</td>
          <td class="numeric-column">&mdash;</td>
        </tr>
      {{/each}}
    </tbody>
  </table>

  {{!-- Special moves — 4-column layout --}}
  {{#if martialArtsSpecialMoves.length}}
    <div class="ma-specials-grid">
      {{#each martialArtsSpecialMoves as |move|}}
        <div class="ma-special-entry">
          <div class="ma-special-header">
            <button type="button"
              class="ma-special-btn"
              data-action="ma-special"
              data-move-id="{{move.id}}">
              <i class="fas fa-fist-raised"></i>
              {{move.name}}
            </button>
          </div>
          <div class="ma-special-desc">{{move.desc}}</div>
        </div>
      {{/each}}
    </div>
  {{/if}}
</section>
