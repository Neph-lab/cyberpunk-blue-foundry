<form class="cyberpunk-blue sheet actor program flexcol" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Name" />
      </h1>
      <div class="header-stats">
        <label class="header-stat" title="Actions">
          <span class="stat-short">ACT</span>
          <input type="number" name="system.stats.act.value" value="{{system.stats.act.value}}" data-dtype="Number" {{#unless isGM}}disabled{{/unless}} />
        </label>
        <label class="header-stat" title="Attack">
          <span class="stat-short">ATK</span>
          <div class="stat-with-roll">
            <input type="number" name="system.stats.atk.value" value="{{system.stats.atk.value}}" data-dtype="Number" {{#unless isGM}}disabled{{/unless}} />
            <button type="button" data-action="roll-atk" title="Roll ATK"><i class="fas fa-dice-d10"></i></button>
          </div>
        </label>
        <label class="header-stat" title="Defense">
          <span class="stat-short">DEF</span>
          <input type="number" name="system.stats.def.value" value="{{system.stats.def.value}}" data-dtype="Number" {{#unless isGM}}disabled{{/unless}} />
        </label>
        <label class="header-stat" title="Net">
          <span class="stat-short">NET</span>
          <input type="number" name="system.stats.net.value" value="{{system.stats.net.value}}" data-dtype="Number" {{#unless isGM}}disabled{{/unless}} />
        </label>
        <label class="header-stat" title="Perception">
          <span class="stat-short">PER</span>
          <div class="stat-with-roll">
            <input type="number" name="system.stats.per.value" value="{{system.stats.per.value}}" data-dtype="Number" {{#unless isGM}}disabled{{/unless}} />
            <button type="button" data-action="roll-per" title="Roll PER"><i class="fas fa-dice-d10"></i></button>
          </div>
        </label>
        <div class="header-stat" title="Rez (digital HP)">
          <span class="stat-short">REZ</span>
          <div class="resource-fields">
            <input type="number" name="system.resources.rez.value" value="{{system.resources.rez.value}}" data-dtype="Number" />
            <span>/</span>
            <input type="number" name="system.resources.rez.max" value="{{system.resources.rez.max}}" data-dtype="Number" {{#unless isGM}}disabled{{/unless}} />
          </div>
        </div>
      </div>
    </div>
  </header>

  {{#if isGM}}
    <div class="program-link-row">
      {{#if link.valid}}
        <span class="program-link-label">
          <i class="fas {{#if link.attached}}fa-paperclip{{else}}fa-link{{/if}}"></i>
          {{#if link.attached}}{{localize "CYBER_BLUE.Netrunning.Program.AttachedLabel"}}{{else}}{{localize "CYBER_BLUE.Netrunning.Program.LinkedLabel"}}{{/if}}:
          <strong>{{link.name}}</strong>
        </span>
        <button type="button" data-action="remove-executable" title="{{localize "CYBER_BLUE.Netrunning.Program.Remove"}}">
          <i class="fas fa-trash"></i>
        </button>
      {{else if link.hasUuid}}
        <span class="program-link-broken" title="{{link.uuid}}">
          <i class="fas fa-triangle-exclamation"></i> {{localize "CYBER_BLUE.Netrunning.Program.BrokenLink"}}
        </span>
        <button type="button" data-action="remove-executable" title="{{localize "CYBER_BLUE.Netrunning.Program.Remove"}}">
          <i class="fas fa-trash"></i>
        </button>
      {{else}}
        <input type="text" name="executableUuidInput" placeholder="{{localize "CYBER_BLUE.Netrunning.Program.UuidPlaceholder"}}" />
        <button type="button" data-action="set-executable-uuid">
          <i class="fas fa-link"></i> {{localize "CYBER_BLUE.Netrunning.Program.LinkBtn"}}
        </button>
        <span class="hint">{{localize "CYBER_BLUE.Netrunning.Program.DropHint"}}</span>
      {{/if}}
    </div>
  {{/if}}

  <div class="program-type-row">
    {{#if isGM}}
      <label>
        <span>Type</span>
        <select name="system.programType">
          {{#each programTypes as |pt|}}
            <option value="{{pt.value}}" {{#if (eq pt.value ../system.programType)}}selected{{/if}}>{{pt.label}}</option>
          {{/each}}
        </select>
      </label>
    {{else}}
      <h2>{{#each programTypes as |pt|}}{{#if (eq pt.value ../system.programType)}}{{pt.label}}{{/if}}{{/each}}</h2>
    {{/if}}
  </div>

  <section class="sheet-body program-body">

    {{!-- ##ERROR## banner --}}
    {{#if inErrorState}}
      <div class="sheet-panel program-error-banner">
        <i class="fas fa-triangle-exclamation"></i>
        <strong>##ERROR##</strong> — REZ 0. Cannot move, act, or provide bonuses. Skipped in encounter order.
      </div>
    {{/if}}

    {{!-- Attack panel (GM only, temp programs with ATK > 0) --}}
    {{#if canAttack}}
      <div class="sheet-panel program-attack-panel">
        <h2>{{localize "CYBER_BLUE.Netrunning.NetCombat.AttackPanel"}}</h2>
        <p class="hint">{{localize "CYBER_BLUE.Netrunning.NetCombat.AttackHint"}}</p>
        <div class="program-attack-row">
          <button type="button" class="net-action-btn" data-action="program-attack" data-damage="1d6">
            <i class="fas fa-bolt"></i> 1d6 {{localize "CYBER_BLUE.Netrunning.NetCombat.StandardDamage"}}
          </button>
        </div>
        {{#if enrichedDescription}}
          <div class="program-attack-function enriched-html">{{{enrichedDescription}}}</div>
        {{/if}}
      </div>
    {{/if}}

    {{!-- Description (non-GM or non-temp programs show it normally) --}}
    {{#unless canAttack}}
      <div class="sheet-panel">
        <h2>Description</h2>
        {{> "systems/cyberpunk-blue/templates/parts/prose-editor.hbs" name="system.description" value=system.description uuid=actor.uuid enriched=enrichedDescription editable=isGM}}
      </div>
    {{/unless}}

    {{#if isGM}}
      <div class="sheet-panel program-notes-panel">
        <h2>Notes (GM only)</h2>
        {{> "systems/cyberpunk-blue/templates/parts/prose-editor.hbs" name="system.notes" value=system.notes uuid=actor.uuid enriched=enrichedNotes editable=isGM}}
      </div>
    {{/if}}
  </section>
</form>
