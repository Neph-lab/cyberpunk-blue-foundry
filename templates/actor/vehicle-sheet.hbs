<form class="cyberpunk-blue sheet actor vehicle flexcol" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Vehicle Name" />
      </h1>
      <div class="header-stats">
        <div class="header-stat" title="Stopping Power">
          <span class="stat-short">SP</span>
          <div class="resource-fields">
            <input type="number" name="system.resources.armor.value" value="{{system.resources.armor.value}}" data-dtype="Number" />
            <span>/</span>
            <input type="number" name="system.resources.armor.max" value="{{system.resources.armor.max}}" data-dtype="Number" {{#unless isGM}}disabled{{/unless}} />
          </div>
        </div>
        <div class="header-stat" title="Hit Points">
          <span class="stat-short">HP</span>
          <div class="resource-fields">
            <input type="number" name="system.resources.hp.value" value="{{system.resources.hp.value}}" data-dtype="Number" />
            <span>/</span>
            <input type="number" name="system.resources.hp.max" value="{{system.resources.hp.max}}" data-dtype="Number" {{#unless isGM}}disabled{{/unless}} />
          </div>
        </div>
        <label class="header-stat" title="Maximum Move (spaces = 2m each)">
          <span class="stat-short">
            <button type="button" data-action="post-move-chat" title="Post MOVE conversion to chat" style="all:unset;cursor:pointer;">MOVE</button>
          </span>
          <input type="number" name="system.stats.move.value" value="{{system.stats.move.value}}" data-dtype="Number" {{#unless isGM}}disabled{{/unless}} />
        </label>
        <label class="header-stat" title="Acceleration">
          <span class="stat-short">ACC</span>
          <input type="number" name="system.stats.acc.accel" value="{{system.stats.acc.accel}}" data-dtype="Number" {{#unless isGM}}disabled{{/unless}} />
        </label>
        <label class="header-stat" title="Type">
          <span class="stat-short">Type</span>
          {{#if isGM}}
            <select name="system.vehicleType">
              {{#each vehicleTypes as |vt|}}
                <option value="{{vt.value}}" {{#if (eq vt.value ../system.vehicleType)}}selected{{/if}}>{{vt.label}}</option>
              {{/each}}
            </select>
          {{else}}
            <span>{{#each vehicleTypes as |vt|}}{{#if (eq vt.value ../system.vehicleType)}}{{vt.label}}{{/if}}{{/each}}</span>
          {{/if}}
        </label>
      </div>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item active" data-tab="general">General</a>
    {{#if isGM}}
      <a class="item" data-tab="notes">Notes</a>
    {{/if}}
  </nav>

  <section class="sheet-body">
    <div class="tab active" data-group="primary" data-tab="general">
      <section class="sheet-panel">
        {{#if isGM}}
          <prose-mirror name="system.description" value="{{system.description}}" document-uuid="{{actor.uuid}}" compact>
            {{{enrichedDescription}}}
          </prose-mirror>
        {{else}}
          <div class="editor"><div class="editor-content">{{{enrichedDescription}}}</div></div>
        {{/if}}
      </section>
    </div>

    {{#if isGM}}
      <div class="tab" data-group="primary" data-tab="notes">
        <section class="sheet-panel">
          <prose-mirror name="system.notes" value="{{system.notes}}" document-uuid="{{actor.uuid}}" compact>
            {{{enrichedNotes}}}
          </prose-mirror>
        </section>
      </div>
    {{/if}}
  </section>
</form>
