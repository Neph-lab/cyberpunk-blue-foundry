<div class="cpb-blueprint-editor">

  {{!-- Toolbar --}}
  <div class="cpb-be-toolbar">
    <div class="cpb-be-tools">
      <button type="button" class="cpb-btn cpb-be-tool active" data-action="tool" data-tool="select"
              title="{{localize "CYBER_BLUE.BlueprintEditor.ToolSelect"}}">
        <i class="fa-solid fa-arrow-pointer"></i>
      </button>
      <button type="button" class="cpb-btn cpb-be-tool" data-action="tool" data-tool="rectangle"
              title="{{localize "CYBER_BLUE.BlueprintEditor.ToolRect"}}">
        <i class="fa-solid fa-vector-square"></i>
      </button>
      <button type="button" class="cpb-btn cpb-be-tool" data-action="tool" data-tool="circle"
              title="{{localize "CYBER_BLUE.BlueprintEditor.ToolCircle"}}">
        <i class="fa-solid fa-circle"></i>
      </button>
      <button type="button" class="cpb-btn cpb-be-tool" data-action="tool" data-tool="ellipse"
              title="{{localize "CYBER_BLUE.BlueprintEditor.ToolEllipse"}}">
        <i class="fa-solid fa-circle-half-stroke"></i>
      </button>
      <button type="button" class="cpb-btn cpb-be-tool" data-action="tool" data-tool="polygon"
              title="{{localize "CYBER_BLUE.BlueprintEditor.ToolPolygon"}}">
        <i class="fa-solid fa-draw-polygon"></i>
      </button>
    </div>

    <button type="button" class="cpb-btn" data-action="fit" title="{{localize "CYBER_BLUE.BlueprintEditor.Fit"}}">
      <i class="fa-solid fa-expand"></i>
    </button>

    <button type="button" class="cpb-btn" data-action="capture" title="{{localize "CYBER_BLUE.BlueprintEditor.CaptureHint"}}">
      <i class="fa-solid fa-cloud-arrow-down"></i>
      {{localize "CYBER_BLUE.BlueprintEditor.Capture"}}
    </button>

    <span class="cpb-be-footprint">
      {{localize "CYBER_BLUE.BlueprintEditor.Footprint"}}:
      {{footprintW}}&times;{{footprintH}}
      <span class="cpb-be-muted">({{referenceGrid}}px/sq)</span>
    </span>

    <span class="cpb-be-status" data-be-status></span>
  </div>

  <div class="cpb-be-main">

    {{!-- Canvas surface --}}
    <div class="cpb-be-canvas-wrap">
      <canvas data-be-canvas tabindex="0"></canvas>
      {{#unless hasArt}}
        <div class="cpb-be-noart">
          <i class="fa-solid fa-image-slash"></i>
          <p>{{localize "CYBER_BLUE.BlueprintEditor.NoArt"}}</p>
        </div>
      {{/unless}}
    </div>

    {{!-- Region list + property panel (populated by JS) --}}
    <aside class="cpb-be-rail" data-be-rail></aside>

  </div>
</div>
