<div class="combat-layout">
  {{#if system.isComputer}}
    <section class="sheet-panel">
      <div class="panel-header"><h2>{{localize "CYBER_BLUE.Sheet.Labels.ComputerConfig"}}</h2></div>
      <div class="computer-fields-grid">
        <label class="compact-field">
          <span>{{localize "CYBER_BLUE.Sheet.Labels.ComputerNodes"}}</span>
          {{#if @root.canManageRestricted}}
            <input type="number" name="system.computer.nodes" value="{{system.computer.nodes}}" data-dtype="Number" min="0" />
          {{else}}
            <div class="readonly-value">{{system.computer.nodes}}</div>
          {{/if}}
        </label>
        <label class="compact-field">
          <span>{{localize "CYBER_BLUE.Sheet.Labels.ComputerHardwareSlots"}}</span>
          {{#if @root.canManageRestricted}}
            <input type="number" name="system.computer.hardwareSlots" value="{{system.computer.hardwareSlots}}" data-dtype="Number" min="0" />
          {{else}}
            <div class="readonly-value">{{system.computer.hardwareSlots}}</div>
          {{/if}}
        </label>
        <label class="compact-field">
          <span>{{localize "CYBER_BLUE.Sheet.Labels.ComputerSoftwareSlots"}}</span>
          {{#if @root.canManageRestricted}}
            <input type="number" name="system.computer.softwareSlots" value="{{system.computer.softwareSlots}}" data-dtype="Number" min="0" />
          {{else}}
            <div class="readonly-value">{{system.computer.softwareSlots}}</div>
          {{/if}}
        </label>
        <label class="compact-field">
          <span>{{localize "CYBER_BLUE.Sheet.Labels.ComputerGeneralSlots"}}</span>
          {{#if @root.canManageRestricted}}
            <input type="number" name="system.computer.generalSlots" value="{{system.computer.generalSlots}}" data-dtype="Number" min="0" />
          {{else}}
            <div class="readonly-value">{{system.computer.generalSlots}}</div>
          {{/if}}
        </label>
        <label class="compact-field">
          <span>{{localize "CYBER_BLUE.Sheet.Labels.ComputerRAM"}}</span>
          {{#if @root.canManageRestricted}}
            <input type="number" name="system.computer.ram" value="{{system.computer.ram}}" data-dtype="Number" min="0" />
          {{else}}
            <div class="readonly-value">{{system.computer.ram}}</div>
          {{/if}}
        </label>
        <label class="checkbox-label">
          <span>{{localize "CYBER_BLUE.Sheet.Labels.ComputerIsCyberdeck"}}</span>
          {{#if @root.canManageRestricted}}
            <input type="checkbox" name="system.computer.isCyberdeck" {{checked system.computer.isCyberdeck}} />
          {{else}}
            <span class="readonly-icon"><i class="fas {{#if system.computer.isCyberdeck}}fa-check{{else}}fa-xmark{{/if}}"></i></span>
          {{/if}}
        </label>
        <label class="checkbox-label">
          <span>{{localize "CYBER_BLUE.Sheet.Labels.ComputerCanQuickhack"}}</span>
          {{#if @root.canManageRestricted}}
            <input type="checkbox" name="system.computer.canQuickhack" {{checked system.computer.canQuickhack}} />
          {{else}}
            <span class="readonly-icon"><i class="fas {{#if system.computer.canQuickhack}}fa-check{{else}}fa-xmark{{/if}}"></i></span>
          {{/if}}
        </label>
      </div>
    </section>
  {{/if}}
  {{#if system.isArmor}}
    <section class="sheet-panel">
      <div class="item-meta-row combat-armor-row">
        <label class="armor-inline-field">
          <span>{{localize "CYBER_BLUE.Sheet.Labels.StoppingPower"}}</span>
          <div class="resource-fields">
            <input type="number" name="system.armor.currentSp" value="{{system.armor.currentSp}}" data-dtype="Number" />
            <span>/</span>
            <input type="number" name="system.armor.maxSp" value="{{system.armor.maxSp}}" data-dtype="Number" />
          </div>
        </label>
      </div>
    </section>
  {{/if}}

  {{#if showWeaponSection}}
    <section class="sheet-panel">
      <div class="panel-header">
        <h2>{{localize "CYBER_BLUE.Sheet.Labels.Weapons"}}</h2>
        {{#if canManageRestricted}}
          <button type="button" data-action="add-weapon" title="{{localize "CYBER_BLUE.Sheet.Buttons.AddWeapon"}}">
            <i class="fas fa-plus"></i>
          </button>
        {{/if}}
      </div>

      {{#if weapons.length}}
        <div class="weapon-list">
          {{#each weapons as |weapon|}}
            <section class="weapon-block">
              <div class="panel-header">
                <h3>{{weapon.definition.label}}</h3>
                {{#if @root.canManageRestricted}}
                  <button type="button" data-action="remove-weapon" data-weapon-index="{{weapon.index}}" title="{{localize "CYBER_BLUE.Sheet.Buttons.RemoveWeapon"}}">
                    <i class="fas fa-trash"></i>
                  </button>
                {{/if}}
              </div>

              <div class="weapon-grid">
                <label>
                  <span>{{localize "CYBER_BLUE.Sheet.Labels.WeaponType"}}</span>
                  <select data-weapon-index="{{weapon.index}}" data-weapon-type-select>
                    {{#each @root.combatConfig.weaponTypeGroups as |group|}}
                      <optgroup label="{{group.label}}">
                        {{#each group.options as |option|}}
                          <option value="{{option.value}}" {{#if (eq option.value weapon.type)}}selected{{/if}}>{{option.label}}</option>
                        {{/each}}
                      </optgroup>
                    {{/each}}
                  </select>
                </label>

                <label>
                  <span>{{localize "CYBER_BLUE.Sheet.Labels.WeaponSkill"}}</span>
                  <select name="system.weapons.{{weapon.index}}.skill">
                    {{#each weapon.skillOptions as |option|}}
                      <option value="{{option.value}}" {{#if (eq option.value weapon.skill)}}selected{{/if}}>{{option.label}}</option>
                    {{/each}}
                  </select>
                </label>

                <label>
                  <span>{{localize "CYBER_BLUE.Sheet.Labels.Damage"}}</span>
                  <input type="text" name="system.weapons.{{weapon.index}}.damage" value="{{weapon.damage}}" />
                </label>

                {{#if weapon.definition.showRateOfFire}}
                  <label class="compact-field">
                    <span>{{localize "CYBER_BLUE.Sheet.Labels.RateOfFire"}}</span>
                    <input type="number" name="system.weapons.{{weapon.index}}.rateOfFire" value="{{weapon.rateOfFire}}" data-dtype="Number" />
                  </label>
                {{/if}}

                {{#if weapon.definition.showMagazine}}
                  <label class="compact-field">
                    <span>{{localize "CYBER_BLUE.Sheet.Labels.Mag"}}</span>
                    <div class="resource-fields">
                      <input type="number" name="system.weapons.{{weapon.index}}.ammoCurrent" value="{{weapon.ammoCurrent}}" data-dtype="Number" />
                      <span>/</span>
                      <input type="number" name="system.weapons.{{weapon.index}}.magazine" value="{{weapon.magazine}}" data-dtype="Number" />
                    </div>
                  </label>
                {{/if}}

                {{#if weapon.definition.showShots}}
                  <label class="compact-field">
                    <span>{{localize "CYBER_BLUE.Sheet.Labels.Shots"}}</span>
                    <input type="number" name="system.weapons.{{weapon.index}}.shots" value="{{weapon.shots}}" data-dtype="Number" />
                  </label>
                {{/if}}

                {{#if weapon.definition.usesMagazine}}
                  <label class="compact-field ammo-type-field">
                    <span>{{localize "CYBER_BLUE.Sheet.Labels.AmmoType"}}</span>
                    {{#if @root.canManageRestricted}}
                      <input type="text" name="system.weapons.{{weapon.index}}.ammoTypeUuid" value="{{weapon.ammoTypeUuid}}" placeholder="UUID..." class="ammo-uuid-input" />
                      {{#if weapon.ammoTypeName}}<span class="ammo-type-resolved">{{weapon.ammoTypeName}}</span>{{/if}}
                    {{else if weapon.ammoTypeResolved}}
                      <span class="ammo-type-resolved">{{weapon.ammoTypeName}}</span>
                    {{else if weapon.ammoTypeName}}
                      <span class="hint ammo-type-missing">{{weapon.ammoTypeName}}</span>
                    {{else}}
                      <span class="hint">—</span>
                    {{/if}}
                  </label>
                {{/if}}

                <label class="compact-field">
                  <span>{{localize "CYBER_BLUE.Sheet.Labels.Hands"}}</span>
                  <input type="number" name="system.weapons.{{weapon.index}}.hands" value="{{weapon.hands}}" data-dtype="Number" />
                </label>

                <label class="checkbox-label">
                  <span>{{localize "CYBER_BLUE.Sheet.Labels.Concealable"}}</span>
                  <input type="checkbox" name="system.weapons.{{weapon.index}}.concealable" {{checked weapon.concealable}} />
                </label>

                {{#if weapon.definition.isThrown}}
                  <label class="checkbox-label" title="{{localize "CYBER_BLUE.Sheet.Labels.ConsumableThrownHint"}}">
                    <span>{{localize "CYBER_BLUE.Sheet.Labels.ConsumableThrown"}}</span>
                    <input type="checkbox" name="system.weapons.{{weapon.index}}.consumableThrown" {{checked weapon.consumableThrown}} />
                  </label>
                {{/if}}

                <fieldset class="weapon-damage-type-group">
                  <legend>{{localize "CYBER_BLUE.Sheet.Labels.DamageType"}}</legend>
                  <label class="checkbox-label">
                    <span>{{localize "CYBER_BLUE.Sheet.Labels.DamageTypeNone"}}</span>
                    <input type="radio" data-weapon-damage-type data-weapon-index="{{weapon.index}}" value="" {{#if (eq weapon.damageType "")}}checked{{/if}} />
                  </label>
                  <label class="checkbox-label">
                    <span>{{localize "CYBER_BLUE.Sheet.Labels.Autofire"}}</span>
                    <input type="radio" data-weapon-damage-type data-weapon-index="{{weapon.index}}" value="autofire" {{#if (eq weapon.damageType "autofire")}}checked{{/if}} />
                  </label>
                  <label class="checkbox-label">
                    <span>{{localize "CYBER_BLUE.Sheet.Labels.Cone"}}</span>
                    <input type="radio" data-weapon-damage-type data-weapon-index="{{weapon.index}}" value="cone" {{#if (eq weapon.damageType "cone")}}checked{{/if}} />
                  </label>
                  <label class="checkbox-label">
                    <span>{{localize "CYBER_BLUE.Sheet.Labels.Explosion"}}</span>
                    <input type="radio" data-weapon-damage-type data-weapon-index="{{weapon.index}}" value="explosion" {{#if (eq weapon.damageType "explosion")}}checked{{/if}} />
                  </label>
                  <label class="checkbox-label">
                    <span>{{localize "CYBER_BLUE.Sheet.Labels.Affliction"}}</span>
                    <input type="radio" data-weapon-damage-type data-weapon-index="{{weapon.index}}" value="affliction" {{#if (eq weapon.damageType "affliction")}}checked{{/if}} />
                  </label>
                  <label class="checkbox-label">
                    <span>{{localize "CYBER_BLUE.Sheet.Labels.AfflictionCone"}}</span>
                    <input type="radio" data-weapon-damage-type data-weapon-index="{{weapon.index}}" value="affliction-cone" {{#if (eq weapon.damageType "affliction-cone")}}checked{{/if}} />
                  </label>
                  <label class="checkbox-label">
                    <span>{{localize "CYBER_BLUE.Sheet.Labels.AfflictionExplosion"}}</span>
                    <input type="radio" data-weapon-damage-type data-weapon-index="{{weapon.index}}" value="affliction-explosion" {{#if (eq weapon.damageType "affliction-explosion")}}checked{{/if}} />
                  </label>
                </fieldset>

                <fieldset class="weapon-class-group">
                  <legend>{{localize "CYBER_BLUE.Sheet.Labels.WeaponClass"}}</legend>
                  <label class="checkbox-label">
                    <span>{{localize "CYBER_BLUE.Sheet.Labels.WeaponClassNone"}}</span>
                    <input type="radio" data-weapon-class data-weapon-index="{{weapon.index}}" value="none" {{#if (eq weapon.weaponClass "none")}}checked{{/if}} />
                  </label>
                  <label class="checkbox-label">
                    <span>{{localize "CYBER_BLUE.Sheet.Labels.WeaponClassPower"}}</span>
                    <input type="radio" data-weapon-class data-weapon-index="{{weapon.index}}" value="power" {{#if (eq weapon.weaponClass "power")}}checked{{/if}} />
                  </label>
                  <label class="checkbox-label">
                    <span>{{localize "CYBER_BLUE.Sheet.Labels.WeaponClassSmart"}}</span>
                    <input type="radio" data-weapon-class data-weapon-index="{{weapon.index}}" value="smart" {{#if (eq weapon.weaponClass "smart")}}checked{{/if}} />
                  </label>
                  <label class="checkbox-label">
                    <span>{{localize "CYBER_BLUE.Sheet.Labels.WeaponClassTech"}}</span>
                    <input type="radio" data-weapon-class data-weapon-index="{{weapon.index}}" value="tech" {{#if (eq weapon.weaponClass "tech")}}checked{{/if}} />
                  </label>
                </fieldset>
              </div>

              {{#if (eq weapon.damageType "autofire")}}
                <div class="weapon-subfields">
                  <label class="compact-field">
                    <span>{{localize "CYBER_BLUE.Sheet.Labels.AutofireMultiplier"}}</span>
                    <input type="number" name="system.weapons.{{weapon.index}}.autofireMultiplier" value="{{weapon.autofireMultiplier}}" step="0.5" min="0.5" />
                  </label>
                  <div class="weapon-range-table-wrap">
                    <p class="hint">{{localize "CYBER_BLUE.Sheet.Labels.AutofireRangeTable"}}</p>
                    <table class="weapon-range-table">
                      <thead>
                        <tr>
                          {{#each weapon.autofireRangeBands as |band|}}
                            <th>{{band.label}}</th>
                          {{/each}}
                        </tr>
                      </thead>
                      <tbody>
                        <tr>
                          {{#each weapon.autofireRangeBands as |band|}}
                            <td class="{{#if band.isBlocked}}is-blocked{{/if}}">
                              <input type="text" value="{{band.displayValue}}" data-autofire-range-input data-weapon-index="{{weapon.index}}" data-band-index="{{band.index}}" />
                            </td>
                          {{/each}}
                        </tr>
                      </tbody>
                    </table>
                  </div>
                </div>
              {{/if}}

              {{#if (or (or (or (eq weapon.damageType "cone") (eq weapon.damageType "explosion")) (eq weapon.damageType "affliction-cone")) (eq weapon.damageType "affliction-explosion"))}}
                <div class="weapon-subfields cone-fields">
                  {{#if (or (eq weapon.damageType "cone") (eq weapon.damageType "affliction-cone"))}}
                    <label class="compact-field">
                      <span>{{localize "CYBER_BLUE.Sheet.Labels.ConeSpread"}}</span>
                      <input type="number" name="system.weapons.{{weapon.index}}.coneSpread" value="{{weapon.coneSpread}}" data-dtype="Number" min="0" />
                    </label>
                    <label class="compact-field">
                      <span>{{localize "CYBER_BLUE.Sheet.Labels.ConeAngle"}}</span>
                      <input type="number" name="system.weapons.{{weapon.index}}.coneAngle" value="{{weapon.coneAngle}}" data-dtype="Number" min="0" max="360" />
                    </label>
                  {{else}}
                    <label class="compact-field">
                      <span>{{localize "CYBER_BLUE.Sheet.Labels.ExplosionSpread"}}</span>
                      <input type="number" name="system.weapons.{{weapon.index}}.coneSpread" value="{{weapon.coneSpread}}" data-dtype="Number" min="0" />
                    </label>
                  {{/if}}
                  <label class="compact-field">
                    <span>{{localize "CYBER_BLUE.Sheet.Labels.ConeHalfDamageDistance"}}</span>
                    <input type="number" name="system.weapons.{{weapon.index}}.coneHalfDamageDistance" value="{{weapon.coneHalfDamageDistance}}" data-dtype="Number" min="0" />
                  </label>

                  <label class="compact-field media-field">
                    <span>{{localize "CYBER_BLUE.Sheet.Labels.EffectMedia"}}</span>
                    <file-picker name="system.weapons.{{weapon.index}}.effectMedia" value="{{weapon.effectMedia}}" type="video"></file-picker>
                  </label>
                  <label class="compact-field">
                    <span>{{localize "CYBER_BLUE.Sheet.Labels.MediaTint"}}</span>
                    <color-picker name="system.weapons.{{weapon.index}}.effectMediaTint" value="{{weapon.effectMediaTint}}"></color-picker>
                  </label>
                </div>
              {{/if}}

              {{#if (or (or (eq weapon.damageType "affliction") (eq weapon.damageType "affliction-cone")) (eq weapon.damageType "affliction-explosion"))}}
                <div class="weapon-subfields affliction-fields">
                  <p class="hint"><i class="fas fa-biohazard"></i> {{localize "CYBER_BLUE.Combat.AfflictionHint"}}</p>
                  <label class="compact-field">
                    <span>{{localize "CYBER_BLUE.Combat.AfflictionPrimary"}}</span>
                    <select name="system.weapons.{{weapon.index}}.afflictionPrimary">
                      {{#each @root.afflictionStatOptions as |opt|}}
                        <option value="{{opt.value}}" {{#if (eq opt.value weapon.afflictionPrimary)}}selected{{/if}}>{{opt.label}}</option>
                      {{/each}}
                    </select>
                  </label>
                  <label class="compact-field">
                    <span>{{localize "CYBER_BLUE.Combat.AfflictionSkill"}}</span>
                    <select name="system.weapons.{{weapon.index}}.afflictionSkill">
                      <option value="">—</option>
                      {{#each @root.afflictionSkillOptions as |opt|}}
                        <option value="{{opt.value}}" {{#if (eq opt.value weapon.afflictionSkill)}}selected{{/if}}>{{opt.label}}</option>
                      {{/each}}
                    </select>
                  </label>
                  <label class="compact-field">
                    <span>{{localize "CYBER_BLUE.Combat.AfflictionDV"}}</span>
                    <input type="number" name="system.weapons.{{weapon.index}}.afflictionDv" value="{{weapon.afflictionDv}}" data-dtype="Number" min="0" />
                  </label>
                  <label class="compact-field">
                    <span>{{localize "CYBER_BLUE.Combat.AfflictionEffect"}}</span>
                    {{#if @root.itemDisabledEffects.length}}
                      <select name="system.weapons.{{weapon.index}}.afflictionEffectId">
                        <option value="">— {{localize "CYBER_BLUE.Combat.AfflictionSelectEffect"}} —</option>
                        {{#each @root.itemDisabledEffects as |effect|}}
                          <option value="{{effect.id}}" {{#if (eq effect.id weapon.afflictionEffectId)}}selected{{/if}}>{{effect.name}}</option>
                        {{/each}}
                      </select>
                    {{else}}
                      <span class="hint">{{localize "CYBER_BLUE.Combat.AfflictionNoDisabledEffects"}}</span>
                    {{/if}}
                  </label>
                </div>
              {{/if}}

              {{#if weapon.definition.usesRangeTable}}
                <div class="weapon-range-table-wrap">
                  <table class="weapon-range-table">
                    <thead>
                      <tr>
                        {{#each weapon.rangeBands as |band|}}
                          <th>{{band.label}}</th>
                        {{/each}}
                      </tr>
                    </thead>
                    <tbody>
                      <tr>
                        {{#each weapon.rangeBands as |band|}}
                          <td class="{{#if band.isBlocked}}is-blocked{{/if}}">
                            <input type="text" value="{{band.displayValue}}" data-range-input data-weapon-index="{{weapon.index}}" data-band-index="{{band.index}}" />
                          </td>
                        {{/each}}
                      </tr>
                    </tbody>
                  </table>
                </div>
              {{/if}}
            </section>
          {{/each}}
        </div>
      {{else}}
        <p class="hint">{{localize "CYBER_BLUE.Sheet.Labels.NoWeapons"}}</p>
      {{/if}}
    </section>
  {{/if}}
</div>
