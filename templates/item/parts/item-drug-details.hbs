{{!-- Drug phase details — shown in the Details tab for Drug items --}}
{{#if isDrug}}
<section class="sheet-panel drug-details-panel">
  <div class="panel-header"><span>{{localize "CYBER_BLUE.Drug.PrimaryEffect"}}</span></div>
  <div class="editor-container">
    {{> "systems/cyberpunk-blue/templates/parts/prose-editor.hbs" name="system.primaryEffect" value=system.primaryEffect uuid=item.uuid enriched=enrichedDrugPrimary editable=editable}}
  </div>

  <div class="item-meta-row">
    <label>
      <span>{{localize "CYBER_BLUE.Drug.Duration"}}</span>
      <input type="text" name="system.duration" value="{{system.duration}}" />
    </label>
    <label class="compact-field">
      <span>{{localize "CYBER_BLUE.Drug.SecondaryDV"}}</span>
      <input type="number" name="system.secondaryDv" value="{{system.secondaryDv}}" data-dtype="Number" min="0" />
    </label>
  </div>

  <div class="panel-header"><span>{{localize "CYBER_BLUE.Drug.SecondaryEffect"}}</span></div>
  <div class="editor-container">
    {{> "systems/cyberpunk-blue/templates/parts/prose-editor.hbs" name="system.secondaryEffect" value=system.secondaryEffect uuid=item.uuid enriched=enrichedDrugSecondary editable=editable}}
  </div>

  <div class="panel-header"><span>{{localize "CYBER_BLUE.Drug.AddictionPenalty"}}</span></div>
  <div class="editor-container">
    {{> "systems/cyberpunk-blue/templates/parts/prose-editor.hbs" name="system.addictionPenalty" value=system.addictionPenalty uuid=item.uuid enriched=enrichedDrugAddiction editable=editable}}
  </div>
</section>
{{/if}}
