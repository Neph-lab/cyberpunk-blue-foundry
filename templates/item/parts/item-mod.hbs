<section class="sheet-body mod-sheet-body">
  <section class="sheet-panel">
    {{> "systems/cyberpunk-blue/templates/parts/prose-editor.hbs" name="system.description" value=system.description uuid=item.uuid enriched=enrichedDescription editable=canEditAsOwner}}
  </section>

  {{#if (eq system.modType "weaponMod")}}
    <section class="sheet-panel">
      <div class="panel-header panel-actions">
        <h2>Weapon Changes</h2>
        {{#if canManageRestricted}}
          <button type="button" data-action="add-mod-weapon-change" title="Add change">
            <i class="fas fa-plus"></i>
          </button>
        {{/if}}
      </div>

      {{#if canManageRestricted}}
        <div class="item-meta-row">
          <label class="compact-field">
            <span>Target Weapon #</span>
            <input type="number" name="system.targetWeaponIndex" value="{{system.targetWeaponIndex}}" data-dtype="Number" min="-1" />
          </label>
        </div>
      {{/if}}

      {{#if system.weaponChanges.length}}
        <table class="weapon-changes-table">
          <thead>
            <tr>
              <th>Field</th>
              <th>Mode</th>
              <th>Value</th>
              {{#if canManageRestricted}}<th></th>{{/if}}
            </tr>
          </thead>
          <tbody>
            {{#each system.weaponChanges as |change|}}
              <tr>
                <td>
                  {{#if @root.canManageRestricted}}
                    <select name="system.weaponChanges.{{@index}}.key">
                      {{#each @root.weaponModFields as |field|}}
                        <option value="{{field.value}}" {{#if (eq field.value change.key)}}selected{{/if}}>{{field.label}}</option>
                      {{/each}}
                    </select>
                  {{else}}
                    {{#each @root.weaponModFields as |field|}}{{#if (eq field.value change.key)}}{{field.label}}{{/if}}{{/each}}
                  {{/if}}
                </td>
                <td>
                  {{#if @root.canManageRestricted}}
                    <select name="system.weaponChanges.{{@index}}.mode">
                      {{#each @root.weaponModModes as |mode|}}
                        <option value="{{mode.value}}" {{#if (eq mode.value change.mode)}}selected{{/if}}>{{mode.label}}</option>
                      {{/each}}
                    </select>
                  {{else}}
                    {{#each @root.weaponModModes as |mode|}}{{#if (eq mode.value change.mode)}}{{mode.label}}{{/if}}{{/each}}
                  {{/if}}
                </td>
                <td>
                  {{#if @root.canManageRestricted}}
                    <input type="text" name="system.weaponChanges.{{@index}}.value" value="{{change.value}}" />
                  {{else}}
                    <span>{{change.value}}</span>
                  {{/if}}
                </td>
                {{#if @root.canManageRestricted}}
                  <td>
                    <button type="button" data-action="remove-mod-weapon-change" data-change-index="{{@index}}" title="Remove">
                      <i class="fas fa-trash"></i>
                    </button>
                  </td>
                {{/if}}
              </tr>
            {{/each}}
          </tbody>
        </table>
      {{else}}
        <p class="hint">No weapon changes defined.</p>
      {{/if}}
    </section>

    {{#if canManageRestricted}}
      <section class="sheet-panel">
        <div class="panel-header"><h2>Applied Toxin / Affliction</h2></div>
        <label class="compact-field">
          <input type="checkbox" name="system.appliesAffliction" {{checked system.appliesAffliction}} />
          <span>Delivers an affliction on a hit that draws blood</span>
        </label>
        {{#if system.appliesAffliction}}
          <div class="item-meta-row">
            <label class="compact-field">
              <span>Save stat</span>
              <select name="system.afflictionPrimary">
                {{#each afflictionStatOptions as |opt|}}
                  <option value="{{opt.value}}" {{#if (eq opt.value @root.item.system.afflictionPrimary)}}selected{{/if}}>{{opt.label}}</option>
                {{/each}}
              </select>
            </label>
            <label class="compact-field">
              <span>Save skill</span>
              <select name="system.afflictionSkill">
                <option value="" {{#if (eq "" system.afflictionSkill)}}selected{{/if}}>—</option>
                {{#each afflictionSkillOptions as |opt|}}
                  <option value="{{opt.value}}" {{#if (eq opt.value @root.item.system.afflictionSkill)}}selected{{/if}}>{{opt.label}}</option>
                {{/each}}
              </select>
            </label>
            <label class="compact-field">
              <span>DV</span>
              <input type="number" name="system.afflictionDv" value="{{system.afflictionDv}}" data-dtype="Number" min="0" />
            </label>
          </div>
          <div class="item-meta-row">
            <label class="compact-field">
              <span>Damage on fail</span>
              <input type="text" name="system.afflictionDamageFormula" value="{{system.afflictionDamageFormula}}" placeholder="2d6" />
            </label>
            <label class="compact-field">
              <span>Damage on resist</span>
              <input type="text" name="system.afflictionResistDamage" value="{{system.afflictionResistDamage}}" placeholder="1d6" />
            </label>
            <label class="compact-field">
              <span>Duration (min)</span>
              <input type="text" name="system.afflictionDurationFormula" value="{{system.afflictionDurationFormula}}" placeholder="40 - 2 * body" />
            </label>
          </div>
          <p class="hint">On a failed save the mod's affliction Active Effect (flagged <em>isAfflictionEffect</em>, below) is applied to the target for the duration. <code>body</code> in the duration is the target's BODY.</p>
        {{/if}}
      </section>
    {{/if}}
  {{/if}}

  {{#if showEffectsTab}}
    <section class="sheet-panel">
      {{> "systems/cyberpunk-blue/templates/item/parts/item-effects.hbs"}}
    </section>
  {{/if}}
</section>
