<div class="tab" data-group="primary" data-tab="mods">
  <section class="sheet-panel embedded-mods-panel">
    <div class="panel-header">
      <h2>{{localize "CYBER_BLUE.Sheet.Labels.Modifications"}}</h2>
      <button type="button" data-action="sync-embedded-mods" class="panel-header-btn" title="{{localize "CYBER_BLUE.Sheet.Labels.ModSyncAll"}}">
        <i class="fas fa-rotate"></i>
      </button>
    </div>
    <div class="embedded-mod-import-row">
      <input type="text" data-mod-import-uuid placeholder="{{localize "CYBER_BLUE.Sheet.Labels.ModImportUuidPlaceholder"}}" />
      <button type="button" data-action="import-mod-by-uuid">{{localize "CYBER_BLUE.Sheet.Labels.ModImport"}}</button>
    </div>
  </section>

  {{#if embeddedMods.length}}
    {{#each embeddedMods as |mod|}}
      <section class="sheet-panel embedded-mod-card">
        <div class="panel-header">
          <h3>{{mod.name}}</h3>
          <span class="state-chip">{{mod.typeLabel}}</span>
          {{#if @root.canEditAsOwner}}
            <button type="button" data-action="remove-embedded-mod" data-mod-id="{{mod.id}}" class="icon-btn danger" title="{{localize "CYBER_BLUE.Sheet.Buttons.Delete"}}">
              <i class="fas fa-trash"></i>
            </button>
          {{/if}}
        </div>

        {{#if mod.note}}
          <p class="mod-note">{{mod.note}}</p>
        {{/if}}

        {{#if mod.enrichedDescription}}
          <div class="enriched-html mod-description">{{{mod.enrichedDescription}}}</div>
        {{/if}}

        {{#if mod.weaponChanges.length}}
          <div class="mod-changes">
            <p class="hint">{{localize "CYBER_BLUE.Sheet.Labels.WeaponAdjustments"}}{{#if mod.weaponLabel}} ({{mod.weaponLabel}}){{/if}}</p>
            <table class="mod-changes-table">
              <thead>
                <tr>
                  <th>{{localize "CYBER_BLUE.Sheet.Labels.Details"}}</th>
                  <th>{{localize "CYBER_BLUE.Sheet.Labels.Modifier"}}</th>
                  <th>{{localize "CYBER_BLUE.Sheet.Labels.Summary"}}</th>
                </tr>
              </thead>
              <tbody>
                {{#each mod.weaponChanges as |change|}}
                  <tr>
                    <td>{{change.key}}</td>
                    <td>{{change.mode}}</td>
                    <td>{{change.value}}</td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        {{/if}}

        {{#if @root.canManageRestricted}}
          {{#if mod.importedEffects.length}}
            <div class="mod-changes">
              <p class="hint">{{localize "CYBER_BLUE.Sheet.Labels.ActiveEffects"}}</p>
              {{#each mod.importedEffects as |effect|}}
                <div class="mod-effect-row">
                  {{#if effect.icon}}<img src="{{effect.icon}}" class="mod-effect-icon" />{{/if}}
                  <strong class="mod-effect-label">{{effect.label}}</strong>
                  {{#if effect.changes.length}}
                    <table class="mod-changes-table">
                      <tbody>
                        {{#each effect.changes as |ch|}}
                          <tr>
                            <td>{{ch.key}}</td>
                            <td>{{ch.value}}</td>
                          </tr>
                        {{/each}}
                      </tbody>
                    </table>
                  {{/if}}
                </div>
              {{/each}}
            </div>
          {{/if}}
        {{/if}}
      </section>
    {{/each}}
  {{else}}
    <section class="sheet-panel">
      <p class="no-content-hint">{{localize "CYBER_BLUE.Sheet.Labels.NoModifications"}}</p>
    </section>
  {{/if}}
</div>
