<div class="program-executable-sheet-body">
  <section class="sheet-panel">
    <div class="item-meta-row program-exec-header">
      <label>
        <span>Type</span>
        {{#if canManageRestricted}}
          <select name="system.programType">
            {{#each programTypes as |pt|}}
              <option value="{{pt.value}}" {{#if (eq pt.value ../system.programType)}}selected{{/if}}>{{pt.label}}</option>
            {{/each}}
          </select>
        {{else}}
          <div class="readonly-value">
            {{#each programTypes as |pt|}}{{#if (eq pt.value ../system.programType)}}{{pt.label}}{{/if}}{{/each}}
          </div>
        {{/if}}
      </label>
    </div>

    <div class="item-meta-row program-stats-row">
      <label class="compact-field">
        <span>ACT</span>
        <input type="number" name="system.act" value="{{system.act}}" data-dtype="Number" {{#unless canManageRestricted}}disabled{{/unless}} />
      </label>
      <label class="compact-field">
        <span>ATK</span>
        <div class="stat-with-roll">
          <input type="number" name="system.atk" value="{{system.atk}}" data-dtype="Number" {{#unless canManageRestricted}}disabled{{/unless}} />
          <button type="button" data-action="roll-executable-atk" title="Roll 1d10+ATK">
            <i class="fas fa-dice-d10"></i>
          </button>
        </div>
      </label>
      <label class="compact-field">
        <span>DEF</span>
        <input type="number" name="system.def" value="{{system.def}}" data-dtype="Number" {{#unless canManageRestricted}}disabled{{/unless}} />
      </label>
      <label class="compact-field">
        <span>NET</span>
        <input type="number" name="system.net" value="{{system.net}}" data-dtype="Number" {{#unless canManageRestricted}}disabled{{/unless}} />
      </label>
      <label class="compact-field">
        <span>PER</span>
        <div class="stat-with-roll">
          <input type="number" name="system.per" value="{{system.per}}" data-dtype="Number" {{#unless canManageRestricted}}disabled{{/unless}} />
          <button type="button" data-action="roll-executable-per" title="Roll 1d10+PER">
            <i class="fas fa-dice-d10"></i>
          </button>
        </div>
      </label>
      <label class="compact-field">
        <span>REZ</span>
        <div class="resource-fields">
          <input type="number" name="system.rez.value" value="{{system.rez.value}}" data-dtype="Number" />
          <span>/</span>
          <input type="number" name="system.rez.max" value="{{system.rez.max}}" data-dtype="Number" {{#unless canManageRestricted}}disabled{{/unless}} />
        </div>
      </label>
    </div>
  </section>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item active" data-tab="description">Description</a>
    {{#if showProgramExecutableNotesTab}}
      <a class="item" data-tab="notes">Notes</a>
    {{/if}}
  </nav>

  <section class="sheet-body">
    <div class="tab active" data-group="primary" data-tab="description">
      <section class="sheet-panel">
        {{#if canEditAsOwner}}
          <prose-mirror name="system.description" value="{{system.description}}" document-uuid="{{item.uuid}}" compact>
            {{{enrichedDescription}}}
          </prose-mirror>
        {{else}}
          <div class="editor"><div class="editor-content">{{{enrichedDescription}}}</div></div>
        {{/if}}
      </section>
    </div>

    {{#if showProgramExecutableNotesTab}}
      <div class="tab" data-group="primary" data-tab="notes">
        <section class="sheet-panel">
          <prose-mirror name="system.notes" value="{{system.notes}}" document-uuid="{{item.uuid}}" compact>
            {{{enrichedNotes}}}
          </prose-mirror>
        </section>
      </div>
    {{/if}}
  </section>
</div>
