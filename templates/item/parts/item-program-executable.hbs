<nav class="sheet-tabs tabs" data-group="primary">
  <a class="item" data-tab="description"><span class="cpb-tab-icon" style="--cpb-icon: url('/systems/cyberpunk-blue/assets/icons/bk_Overview.svg')"></span>{{localize "CYBER_BLUE.Sheet.Tabs.Description"}}</a>
  {{#if showProgramExecutableNotesTab}}
    <a class="item" data-tab="notes"><span class="cpb-tab-icon" style="--cpb-icon: url('/systems/cyberpunk-blue/assets/icons/bk_Notes.svg')"></span>{{localize "CYBER_BLUE.Sheet.Tabs.Notes"}}</a>
  {{/if}}
</nav>

<section class="sheet-body">
  <div class="tab active" data-group="primary" data-tab="description">
    {{#if linkedProgramActorId}}
      <section class="sheet-panel gm-only-panel">
        <div class="program-actor-link">
          <span class="label"><i class="fas fa-microchip"></i> {{localize "CYBER_BLUE.Netrunning.LinkedProgramActor"}}</span>
          <a class="content-link program-actor-open" data-uuid="Actor.{{linkedProgramActorId}}">
            <i class="fas fa-user-astronaut"></i> {{linkedProgramActorName}}
          </a>
        </div>
      </section>
    {{/if}}
    <section class="sheet-panel">
      {{> "systems/cyberpunk-blue/templates/parts/prose-editor.hbs" name="system.description" value=system.description uuid=item.uuid enriched=enrichedDescription editable=canEditAsOwner}}
    </section>
  </div>

  {{#if showProgramExecutableNotesTab}}
    <div class="tab" data-group="primary" data-tab="notes">
      <section class="sheet-panel">
        {{> "systems/cyberpunk-blue/templates/parts/prose-editor.hbs" name="system.notes" value=system.notes uuid=item.uuid enriched=enrichedNotes editable=canEditAsOwner}}
      </section>
    </div>
  {{/if}}
</section>
